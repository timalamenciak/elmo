          "val" : "GROUP:OBI:<http://purl.obolibrary.org/obo/obi>"
        }, {
          "pred" : "http://www.w3.org/2000/01/rdf-schema#isDefinedBy",
          "val" : "http://purl.obolibrary.org/obo/iao.owl"
        } ]
      }
