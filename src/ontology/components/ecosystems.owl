        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620212"/>
        <obo:IAO_0000115 xml:lang="en">A subbiome of the Polar/alpine (cryogenic) biome comprising high-altitude tropical alpine ecosystems characterised by intense UV radiation, large diurnal temperature variation, and distinctive Afroalpine or Andean vegetation forms.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
