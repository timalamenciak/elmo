AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620208> "T2 Temperate-boreal forests and woodlands biome"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620208> "Temperate-boreal forests and woodlands biome"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620208> <http://purl.obolibrary.org/obo/ENVO_01001110>)

# Class: <https://w3id.org/elmo/elmo_3620209> (Shrublands and shrubby woodlands biome)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <https://global-ecosystems.org/explore/biomes/T3>) <http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3620209> "The shrublands and shrub-dominated woodlands biome is a biome that includes oligotrophic systems occurring on acidic, sandy soils that are often shallow or skeletal, distributed across al llandmasses outside the polar regions."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620209> "T3 Shrublands and shrubby woodlands biome"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620209> "Shrublands and shrubby woodlands biome"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620209> <http://purl.obolibrary.org/obo/ENVO_01001110>)

# Class: <https://w3id.org/elmo/elmo_3620210> (Savannas and grasslands biome)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <https://global-ecosystems.org/explore/biomes/T4>) <http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3620210> "The savannas and grasslands biome is a biome that has ecological functions closely linked to a mostly continuous ground layer of grasses that contribute moderate to very high levels of primary productivity driven by strongly seasonal water surplus and deficit cycles."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620210> "T4 Savannas and grasslands biome"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620210> "Savannas and grasslands biome"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620210> <http://purl.obolibrary.org/obo/ENVO_01001110>)

# Class: <https://w3id.org/elmo/elmo_3620211> (Deserts and semi-deserts biome)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <https://global-ecosystems.org/explore/biomes/T5>) <http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3620211> "The deserts and semi-deserts biome is a biome that includes low to very low biomass ecosystems occurring in arid or semi-arid climates, principally associated with the subtropical high-pressure belts and major continental rain shadows."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620211> "T5 Deserts and semi-deserts biome"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620211> "Deserts and semi-deserts biome"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620211> <http://purl.obolibrary.org/obo/ENVO_01001110>)

# Class: <https://w3id.org/elmo/elmo_3620212> (Polar/alpine (cryogenic) biome)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <https://global-ecosystems.org/explore/biomes/T6>) <http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3620212> "the polar/alpine biome is a biome that encompasses the extensive Arctic and Antarctic regions as well as high mountainous areas across all continental land masses, with low or very low primary productivity."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620212> "T6 Polar/alpine (cryogenic) biome"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620212> "Polar/alpine (cryogenic) biome"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620212> <http://purl.obolibrary.org/obo/ENVO_01001110>)

# Class: <https://w3id.org/elmo/elmo_3620213> (Intensive land-use biome)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <https://global-ecosystems.org/explore/biomes/T7>) <http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3620213> "The intensive land-use biome is a biome that includes major anthropogenic enterprises of cropping, pastoralism, plantation farming, and urbanisation. Human intervention is a dominating influence on this biome, also known as the “anthrome”."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620213> "T7 Intensive land-use biome"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620213> "Intensive land-use biome"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620213> <http://purl.obolibrary.org/obo/ENVO_01001110>)

# Class: <https://w3id.org/elmo/elmo_3620214> (Anthropogenic subterranean voids biome)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <https://global-ecosystems.org/explore/biomes/S2>) <http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3620214> "The anthropogenic subterranean voids biome is a biome that  includes a single functional group of ecosystems that owe their genesis to excavation by humans. They include underground mines, transport tunnels, tombs, defence and energy installations, and other infrastructure."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620214> "S2 Anthropogenic subterranean voids biome"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620214> "Anthropogenic subterranean voids biome"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620214> <http://purl.obolibrary.org/obo/ENVO_01001110>)

# Class: <https://w3id.org/elmo/elmo_3620215> (Subterranean freshwaters biome)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <https://global-ecosystems.org/explore/biomes/SF1>) <http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3620215> "The subterranean freshwaters biome is a biome that includes streams, small lakes and aquifers beneath the earth’s surface and potentially has the largest volume of water of all the freshwater biomes."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620215> "SF1 Subterranean freshwaters biome"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620215> "Subterranean freshwaters biome"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620215> <http://purl.obolibrary.org/obo/ENVO_01001110>)

# Class: <https://w3id.org/elmo/elmo_3620216> (Anthropogenic subterranean freshwaters biome)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <https://global-ecosystems.org/explore/biomes/SF2>) <http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3620216> "The anthropogenic subterranean freshwaters biome is a biome that includes aquatic systems in underground canals, drains, sewers, water pipes, and flooded mines constructed by humans. These are usually well connected to surface waters."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620216> "SF2 Anthropogenic subterranean freshwaters biome"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620216> "Anthropogenic subterranean freshwaters biome"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620216> <http://purl.obolibrary.org/obo/ENVO_01001110>)

# Class: <https://w3id.org/elmo/elmo_3620217> (Palustrine wetlands biome)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <https://global-ecosystems.org/explore/biomes/TF1>) <http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3620217> "The palustrine wetlands biome is a biome that includes vegetated floodplains, groundwater seeps, and mires with permanent or intermittent surface water. Although water and light are abundant at least periodically, saturation of the soil may result in oxygen deprivation below the ground. This suppresses microbial activity and, in many systems, production exceeds decomposition, resulting in peat accumulation."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620217> "TF1 Palustrine wetlands biome"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620217> "Palustrine wetlands biome"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620217> <http://purl.obolibrary.org/obo/ENVO_01001110>)

# Class: <https://w3id.org/elmo/elmo_3620218> (Rivers and streams biome)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <https://global-ecosystems.org/explore/biomes/F1>) <http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3620218> "The rivers and streams biome is a biome that includes lotic (running water) ecosystems, flowing from elevated uplands or underground springs to deltas, estuaries, and lakes. They are defined primarily by their linear structure, unidirectional flow regimes, and close interaction with the surrounding landscape."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620218> "F1 Rivers and streams biome"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620218> "Rivers and streams biome"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620218> <http://purl.obolibrary.org/obo/ENVO_01001110>)

# Class: <https://w3id.org/elmo/elmo_3620219> (Lakes biome)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <https://global-ecosystems.org/explore/biomes/F2>) <http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3620219> "The lakes biome is a biome that includes lentic ecosystems defined by their still waters. They vary in area, depth, water regime, and connectivity to other aquatic systems across a global distribution."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620219> "F2 Lakes biome"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620219> "Lakes biome"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620219> <http://purl.obolibrary.org/obo/ENVO_01001110>)

# Class: <https://w3id.org/elmo/elmo_3620220> (Artificial wetlands biome)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <https://global-ecosystems.org/explore/biomes/F3>) <http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3620220> "The artificial wetlands biome is a biome that includes built structures that hold or transfer water for human use, treatment, or disposal, including large storage reservoirs, farm dams or ponds, recreational and ornamental wetlands, rice paddies, freshwater aquafarms, wastewater storages and treatment ponds, and canals, ditches and drains."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620220> "F3 Artificial wetlands biome"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620220> "Artificial wetlands biome"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620220> <http://purl.obolibrary.org/obo/ENVO_01001110>)

# Class: <https://w3id.org/elmo/elmo_3620221> (Semi-confined transitional waters biome)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <https://global-ecosystems.org/explore/biomes/FM1>) <http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3620221> "The semi-confined transitional waters biome is a biome that includes coastal inlets that are influenced by inputs of both fresh and marine water from terrestrial catchments and ocean tides, waves, and currents. They include deep-water coastal inlets or fjords mostly restricted to high latitudes, as well as estuaries, bays, and lagoons, which are scattered around coastlines throughout the world."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620221> "FM1 Semi-confined transitional waters biome"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620221> "Semi-confined transitional waters biome"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620221> <http://purl.obolibrary.org/obo/ENVO_01001110>)

# Class: <https://w3id.org/elmo/elmo_3620222> (Marine shelf biome)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <https://global-ecosystems.org/explore/biomes/M1>) <http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3620222> "The marine shelf biome is a biome that is distributed globally between the shoreline and deep sea-floor biomes and is dominated by benthic productivity. It includes ecosystems with biogenic substrates (such as seagrass meadows, kelp forests, oyster beds, and coral reefs) and minerogenic substrates including rocky reefs, sandy bottoms, and muddy bottoms."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620222> "M1 Marine shelf biome"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620222> "Marine shelf biome"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620222> <http://purl.obolibrary.org/obo/ENVO_01001110>)

# Class: <https://w3id.org/elmo/elmo_3620223> (Pelagic ocean waters biome)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <https://global-ecosystems.org/explore/biomes/M2>) <http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3620223> "The pelagic ocean waters biome is a biome that comprises the open-ocean water column across all latitudes."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620223> "M2 Pelagic ocean waters biome"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620223> "Pelagic ocean waters biome"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620223> <http://purl.obolibrary.org/obo/ENVO_01001110>)

# Class: <https://w3id.org/elmo/elmo_3620224> (Deep sea floors biome)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <https://global-ecosystems.org/explore/biomes/M3>) <http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3620224> "The deep sea floors biome is a biome that includes the entire oceanic benthos below ~250 m depth, where there is not enough light to support primary productivity through photosynthesis. It extends from the upper bathyal seafloor to the deepest parts of the ocean, at just under 11 km in the Mariana Trench."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620224> "M3 Deep sea floors biome"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620224> "Deep sea floors biome"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620224> <http://purl.obolibrary.org/obo/ENVO_01001110>)

# Class: <https://w3id.org/elmo/elmo_3620225> (Anthropogenic marine biome)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <https://global-ecosystems.org/explore/biomes/M4>) <http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3620225> "The anthropogenic marine biome is a biome that includes constructed, deposited or dumped artificial structures in the oceans that either confine managed marine organisms or attract marine biota that would not otherwise occupy such locations."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620225> "M4 Anthropogenic marine biome"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620225> "Anthropogenic marine biome"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620225> <http://purl.obolibrary.org/obo/ENVO_01001110>)

# Class: <https://w3id.org/elmo/elmo_3620226> (Shorelines biome)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <https://global-ecosystems.org/explore/biomes/MT1>) <http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3620226> "The shorelines biome is a biome that includes naturally formed, intertidal abiogenic habitats situated at the interface between land and sea. The distribution of the biome spans all latitudes (temperate to polar) at which landmasses are present."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620226> "MT1 Shorelines biome"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620226> "Shorelines biome"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620226> <http://purl.obolibrary.org/obo/ENVO_01001110>)

# Class: <https://w3id.org/elmo/elmo_3620227> (Supralittoral coast biome)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <https://global-ecosystems.org/explore/biomes/MT2>) <http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3620227> "The supralittoral coastal biome includes the landward extent of the transition from marine to terrestrial biomes. It is elevated above the direct influence of waves and tides (see the Shoreline biome) and beyond the direct influence of freshwater seepage or rivers (see brackish tidal biota). Supratidal coastal ecosystems extend around all the world’s land masses, occupying a fringe from tens of metres to a few kilometres wide and covering the entire extent of many small islands."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620227> "MT2 Supralittoral coast biome"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620227> "Supralittoral coast biome"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620227> <http://purl.obolibrary.org/obo/ENVO_01001110>)

# Class: <https://w3id.org/elmo/elmo_3620228> (Anthropogenic shorelines biome)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <https://global-ecosystems.org/explore/biomes/MT3>) <http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3620228> "The anthropogenic shorelines biome is a biome that is distributed globally where urbanised and industrial areas adjoin the coast, and includes some more remote structures such as artificial islands. It includes marine interfaces constructed from hard, smooth surfaces, including concrete, timber, lithic blocks, and earthen fill, adjoining, extending or replacing natural shores, or floating in proximity to them."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620228> "MT3 Anthropogenic shorelines biome"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620228> "Anthropogenic shorelines biome"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620228> <http://purl.obolibrary.org/obo/ENVO_01001110>)

# Class: <https://w3id.org/elmo/elmo_3620229> (Brackish tidal biome)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <https://global-ecosystems.org/explore/biomes/MFT1>) <http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3620229> "The brackish tidal biome is a biome that is associated with prograding depositional shorelines at the interface of terrestrial, freshwater, and marine realms. The relative influences of marine, freshwater, and terrestrial processes vary from strongly fluvial deltas to marine-dominated intertidal forests and terrestrial-dominated coastal saltmarsh."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620229> "MFT1 Brackish tidal biome"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620229> "Brackish tidal biome"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620229> <http://purl.obolibrary.org/obo/ENVO_01001110>)

# Class: <https://w3id.org/elmo/elmo_3620230> (Tropical alpine grasslands and shrublands)

AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620230> "T6.5 Tropical alpine grasslands and shrublands"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620230> "Tropical alpine grasslands and shrublands"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620230> <https://w3id.org/elmo/elmo_3620212>)

# Class: <https://w3id.org/elmo/elmo_3620231> (Annual croplands)

AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620231> "T7.1 Annual croplands"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620231> "Annual croplands"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620231> <https://w3id.org/elmo/elmo_3620213>)

# Class: <https://w3id.org/elmo/elmo_3620232> (Constructed lacustrine wetlands)

AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620232> "F3.2 Constructed lacustrine wetlands"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620232> "Constructed lacustrine wetlands"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620232> <https://w3id.org/elmo/elmo_3620220>)

# Class: <https://w3id.org/elmo/elmo_3620233> (Marine aquafarms)

AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620233> "M4.2 Marine aquafarms"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620233> "Marine aquafarms"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3620233> <https://w3id.org/elmo/elmo_3620225>)

# Class: <https://w3id.org/elmo/elmo_3620234> (Subterranean lithic biome)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <https://global-ecosystems.org/explore/biomes/S1>) <http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3620234> "The subterranean lithic biome is a biome that includes non-aquatic lithic systems beneath the earth’s surface where sunlight is absent or of insufficient intensity to sustain photosynthesis."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3620234> "S1 Subterranean lithic biome"@en)
