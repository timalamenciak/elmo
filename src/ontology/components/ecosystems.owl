    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620257"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A subbiome of the Intensive land-use biome comprising cultivated croplands, pastures, and managed farmlands characterised by human modification of the land surface for food, fibre, and biomass production.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298957/Agricultural_Land_Subbiome"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620258 -->

