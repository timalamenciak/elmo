    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620260 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620260">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620217"/>
        <obo:IAO_0000115 xml:lang="en">A subbiome of the Palustrine wetlands biome comprising freshwater forested wetlands characterised by waterlogged soils supporting tree-dominated canopies adapted to periodic or permanent inundation.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TP1.a</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TP1.a Forested Wetland Subbiome</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Forested Wetland Subbiome</rdfs:label>
    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620260"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A subbiome of the Palustrine wetlands biome comprising freshwater forested wetlands characterised by waterlogged soils supporting tree-dominated canopies adapted to periodic or permanent inundation.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298960/Forested_Wetland_Subbiome"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620261 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620261">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620217"/>
        <obo:IAO_0000115 xml:lang="en">A subbiome of the Palustrine wetlands biome comprising open freshwater wetlands characterised by emergent herbaceous or shrubby vegetation and standing or slow-moving water with seasonal to permanent inundation.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TP1.b</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TP1.b Emergent Open Wetland Subbiome</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Emergent Open Wetland Subbiome</rdfs:label>
    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620261"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A subbiome of the Palustrine wetlands biome comprising open freshwater wetlands characterised by emergent herbaceous or shrubby vegetation and standing or slow-moving water with seasonal to permanent inundation.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298961/Emergent_Open_Wetland_Subbiome"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620262 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620262">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620217"/>
        <obo:IAO_0000115 xml:lang="en">A subbiome of the Palustrine wetlands biome comprising peat-forming freshwater wetlands characterised by waterlogged, nutrient-poor, and often acidic conditions supporting sphagnum moss, sedge, and heath communities.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TP1.c</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TP1.c Bog &amp; Fen Subbiome</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Bog &amp; Fen Subbiome</rdfs:label>
    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620262"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A subbiome of the Palustrine wetlands biome comprising peat-forming freshwater wetlands characterised by waterlogged, nutrient-poor, and often acidic conditions supporting sphagnum moss, sedge, and heath communities.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298962/Bog_Fen_Subbiome"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620263 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620263">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620238"/>
        <obo:IAO_0000115 xml:lang="en">A subbiome of the Freshwater Coast biome comprising natural freshwater shoreline ecosystems characterised by dynamic water-level fluctuations, wave or current action, and characteristic riparian or lacustrine shore vegetation.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TP2.a</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TP2.a Freshwater Coast Subbiome</oboInOwl:hasExactSynonym>
