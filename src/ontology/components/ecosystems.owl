    <!-- https://w3id.org/elmo/elmo_3620240 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620240">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620207"/>
        <obo:IAO_0000115 xml:lang="en">A subbiome of the Tropical-subtropical forests biome comprising closed-canopy, high-rainfall tropical and subtropical forests characterised by high biodiversity, year-round productivity, and complex multi-layered canopy structure.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TT1.a</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT1.a Tropical Rainforest Subbiome</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Tropical Rainforest Subbiome</rdfs:label>
    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620240"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A subbiome of the Tropical-subtropical forests biome comprising closed-canopy, high-rainfall tropical and subtropical forests characterised by high biodiversity, year-round productivity, and complex multi-layered canopy structure.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298942/Tropical_Rainforest_Subbiome"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620241 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620241">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620207"/>
        <obo:IAO_0000115 xml:lang="en">A subbiome of the Tropical-subtropical forests biome comprising seasonally dry tropical and subtropical forests and thickets characterised by drought-deciduous or semi-deciduous phenology and strongly seasonal productivity.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TT1.b</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT1.b Tropical Dry Forest Subbiome</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Tropical Dry Forest Subbiome</rdfs:label>
    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620241"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A subbiome of the Tropical-subtropical forests biome comprising seasonally dry tropical and subtropical forests and thickets characterised by drought-deciduous or semi-deciduous phenology and strongly seasonal productivity.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298943/Tropical_Dry_Forest_Subbiome"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620242 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620242">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620208"/>
        <obo:IAO_0000115 xml:lang="en">A subbiome of the Temperate-boreal forests and woodlands biome comprising warm temperate forests and woodlands characterised by mixed evergreen-deciduous or evergreen canopies with moderate biodiversity and mild seasonal climates.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TT2.a</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT2.a Warm Temperate Forest &amp; Woodland Subbiome</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Warm Temperate Forest &amp; Woodland Subbiome</rdfs:label>
    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620242"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A subbiome of the Temperate-boreal forests and woodlands biome comprising warm temperate forests and woodlands characterised by mixed evergreen-deciduous or evergreen canopies with moderate biodiversity and mild seasonal climates.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298945/Warm_Temperate_Forest_Woodland_Subbiome"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620243 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620243">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620208"/>
        <obo:IAO_0000115 xml:lang="en">A subbiome of the Temperate-boreal forests and woodlands biome comprising cool temperate forests and woodlands characterised by deciduous or mixed canopies, pronounced seasonality, and moderate to high productivity.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TT2.b</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT2.b Cool Temperate Forest &amp; Woodland Subbiome</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Cool Temperate Forest &amp; Woodland Subbiome</rdfs:label>
    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620243"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A subbiome of the Temperate-boreal forests and woodlands biome comprising cool temperate forests and woodlands characterised by deciduous or mixed canopies, pronounced seasonality, and moderate to high productivity.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1333041/Cool_Temperate_Forest_Woodland_Subbiome"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620244 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620244">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620208"/>
        <obo:IAO_0000115 xml:lang="en">A subbiome of the Temperate-boreal forests and woodlands biome comprising boreal forests and woodlands at high latitudes characterised by coniferous or mixed canopies, cold long winters, and a short growing season.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TT2.c</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT2.c Boreal Forest &amp; Woodland Subbiome</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Boreal Forest &amp; Woodland Subbiome</rdfs:label>
    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620244"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A subbiome of the Temperate-boreal forests and woodlands biome comprising boreal forests and woodlands at high latitudes characterised by coniferous or mixed canopies, cold long winters, and a short growing season.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298944/Boreal_Forest_Woodland_Subbiome"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620245 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620245">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620236"/>
        <obo:IAO_0000115 xml:lang="en">A subbiome of the Tropical Savanna and Shrubland biome comprising open to semi-closed tropical savannas characterised by a continuous grass layer, scattered trees, and strongly seasonal rainfall with a pronounced dry season.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TT3.a</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT3.a Tropical Savanna Subbiome</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Tropical Savanna Subbiome</rdfs:label>
    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620245"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A subbiome of the Tropical Savanna and Shrubland biome comprising open to semi-closed tropical savannas characterised by a continuous grass layer, scattered trees, and strongly seasonal rainfall with a pronounced dry season.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298946/Tropical_Savanna_Subbiome"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620246 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620246">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620236"/>
        <obo:IAO_0000115 xml:lang="en">A subbiome of the Tropical Savanna and Shrubland biome comprising tropical shrublands characterised by woody shrub dominance, often on nutrient-poor or seasonally dry substrates with recurrent disturbance by fire or herbivory.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TT3.b</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT3.b Tropical Shrubland Subbiome</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Tropical Shrubland Subbiome</rdfs:label>
    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620246"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A subbiome of the Tropical Savanna and Shrubland biome comprising tropical shrublands characterised by woody shrub dominance, often on nutrient-poor or seasonally dry substrates with recurrent disturbance by fire or herbivory.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298947/Tropical_Shrubland_Subbiome"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620247 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620247">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620236"/>
        <obo:IAO_0000115 xml:lang="en">A subbiome of the Tropical Savanna and Shrubland biome comprising tropical cliff and rock outcrop ecosystems characterised by exposed rock substrates, extreme microclimate variability, sparse vegetation, and high local endemism.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TT3.c</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT3.c Tropical Open Rock Subbiome</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Tropical Open Rock Subbiome</rdfs:label>
    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620247"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A subbiome of the Tropical Savanna and Shrubland biome comprising tropical cliff and rock outcrop ecosystems characterised by exposed rock substrates, extreme microclimate variability, sparse vegetation, and high local endemism.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298948/Tropical_Open_Rock_Subbiome"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620248 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620248">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620237"/>
        <obo:IAO_0000115 xml:lang="en">A subbiome of the Temperate-Boreal Grassland and Shrubland biome comprising Mediterranean-climate and dry temperate grasslands and shrublands characterised by fire-adapted or drought-adapted vegetation and pronounced summer drought.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TT4.a</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT4.a Mediterranean-Dry Grassland &amp; Shrubland Subbiome</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Mediterranean-Dry Grassland &amp; Shrubland Subbiome</rdfs:label>
    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620248"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A subbiome of the Temperate-Boreal Grassland and Shrubland biome comprising Mediterranean-climate and dry temperate grasslands and shrublands characterised by fire-adapted or drought-adapted vegetation and pronounced summer drought.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1333042/Mediterranean-Dry_Grassland_Shrubland_Subbiome"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620249 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620249">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620237"/>
        <obo:IAO_0000115 xml:lang="en">A subbiome of the Temperate-Boreal Grassland and Shrubland biome comprising temperate grasslands and shrublands characterised by a dominant grass and forb layer with limited woody cover and seasonal moisture deficits.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TT4.b</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT4.b Temperate Grassland &amp; Shrubland Subbiome</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Temperate Grassland &amp; Shrubland Subbiome</rdfs:label>
    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620249"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A subbiome of the Temperate-Boreal Grassland and Shrubland biome comprising temperate grasslands and shrublands characterised by a dominant grass and forb layer with limited woody cover and seasonal moisture deficits.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298949/Temperate_Grassland_Shrubland_Subbiome"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620250 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620250">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620237"/>
        <obo:IAO_0000115 xml:lang="en">A subbiome of the Temperate-Boreal Grassland and Shrubland biome comprising continental boreal shrublands and grasslands at high latitudes characterised by cold continental climates, short growing seasons, and low productivity.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TT4.c</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT4.c Continental Boreal Shrubland &amp; Grassland Subbiome</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Continental Boreal Shrubland &amp; Grassland Subbiome</rdfs:label>
    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620250"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A subbiome of the Temperate-Boreal Grassland and Shrubland biome comprising continental boreal shrublands and grasslands at high latitudes characterised by cold continental climates, short growing seasons, and low productivity.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298950/Continental_Boreal_Shrubland_Grassland_Subbiome"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620251 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620251">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620237"/>
        <obo:IAO_0000115 xml:lang="en">A subbiome of the Temperate-Boreal Grassland and Shrubland biome comprising temperate and boreal cliff and rock outcrop ecosystems characterised by minimal soil development, stress-tolerant vegetation, and high local endemism.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TT4.d</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT4.d Temperate-Boreal Open Rock Subbiome</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Temperate-Boreal Open Rock Subbiome</rdfs:label>
    </Class>
    <Axiom>
