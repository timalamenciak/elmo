        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620239"/>
        <obo:IAO_0000115 xml:lang="en">A subbiome of the Anthropogenic Freshwater Coast biome comprising modified and developed freshwater shoreline ecosystems characterised by human infrastructure, altered hydrological regimes, and degraded or managed shoreline vegetation.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">No link on NatureServe Explorer.</obo:IAO_0000116>
