        <oboInOwl:hasExactSynonym xml:lang="en">TT6.c Tropical Alpine Subbiome</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Tropical Alpine Subbiome</rdfs:label>
    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620256"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A subbiome of the Polar/alpine (cryogenic) biome comprising high-altitude tropical alpine ecosystems characterised by intense UV radiation, large diurnal temperature variation, and distinctive Afroalpine or Andean vegetation forms.</annotatedTarget>
