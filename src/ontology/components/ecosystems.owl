    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620263"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A subbiome of the Freshwater Coast biome comprising natural freshwater shoreline ecosystems characterised by dynamic water-level fluctuations, wave or current action, and characteristic riparian or lacustrine shore vegetation.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298964/Freshwater_Coast_Subbiome"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620264 -->

