        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A subbiome of the Polar/alpine (cryogenic) biome comprising polar and high-altitude snow and ice ecosystems characterised by perennial or semi-permanent ice or snow cover and minimal biological productivity.</annotatedTarget>
