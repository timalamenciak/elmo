    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620269 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620269">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620241"/>
        <obo:IAO_0000115 xml:lang="en">A tropical dry forest ecosystem characterised by thorny, drought-adapted trees and shrubs with sparse to moderate canopy cover, occurring in semi-arid tropical regions with a prolonged dry season.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TT1.b2</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT1.b2 Tropical Thorn Woodland</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Tropical Thorn Woodland</rdfs:label>
    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620269"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A tropical dry forest ecosystem characterised by thorny, drought-adapted trees and shrubs with sparse to moderate canopy cover, occurring in semi-arid tropical regions with a prolonged dry season.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298975/Tropical_Thorn_Woodland_Ecobiome"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620270 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620270">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620243"/>
        <obo:IAO_0000115 xml:lang="en">A cool temperate forest and woodland ecosystem characterised by coniferous tree dominance in continental climates, with cold winters, moderate growing-season productivity, and often a sparse or ericaceous understorey.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TT2.b3</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT2.b3 Temperate Continental Conifer Forest &amp; Woodland</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Temperate Continental Conifer Forest &amp; Woodland</rdfs:label>
    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620270"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A cool temperate forest and woodland ecosystem characterised by coniferous tree dominance in continental climates, with cold winters, moderate growing-season productivity, and often a sparse or ericaceous understorey.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298982/Temperate_Continental_Conifer_Forest_Woodland_Ecobiome"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620271 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620271">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620244"/>
        <obo:IAO_0000115 xml:lang="en">A boreal forest and woodland ecosystem characterised by coniferous tree dominance, a moss- and lichen-dominated understorey, seasonally frozen soils, and a short growing season at high latitudes.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TT2.c1</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT2.c1 Boreal Forest &amp; Woodland</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Boreal Forest &amp; Woodland</rdfs:label>
    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620271"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A boreal forest and woodland ecosystem characterised by coniferous tree dominance, a moss- and lichen-dominated understorey, seasonally frozen soils, and a short growing season at high latitudes.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298976/Boreal_Forest_Woodland_Ecobiome"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620272 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620272">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620245"/>
        <obo:IAO_0000115 xml:lang="en">A tropical savanna ecosystem characterised by a continuous grass layer interspersed with scattered trees or shrubs in lowland tropical regions, maintained by seasonal drought, fire, and herbivory.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TT3.a1</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT3.a1 Tropical Lowland Savanna</oboInOwl:hasExactSynonym>
        <oboInOwl:hasNarrowSynonym xml:lang="en">ELMO:3620114</oboInOwl:hasNarrowSynonym>
        <oboInOwl:hasNarrowSynonym xml:lang="en">ELMO:3620115</oboInOwl:hasNarrowSynonym>
        <oboInOwl:hasNarrowSynonym xml:lang="en">ELMO:3620116</oboInOwl:hasNarrowSynonym>
        <rdfs:label xml:lang="en">Tropical Lowland Savanna</rdfs:label>
    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620272"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A tropical savanna ecosystem characterised by a continuous grass layer interspersed with scattered trees or shrubs in lowland tropical regions, maintained by seasonal drought, fire, and herbivory.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298983/Tropical_Lowland_Savanna_Ecobiome"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620273 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620273">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620247"/>
        <obo:IAO_0000115 xml:lang="en">A tropical open-rock ecosystem characterised by exposed cliff and rock outcrop substrates, minimal soil, extreme microclimate variability, and highly specialised stress-tolerant plant communities with high local endemism.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasBroadSynonym xml:lang="en">ELMO:3620113</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT3.c1</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT3.c1 Tropical Cliff &amp; Rock Outcrop</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Tropical Cliff &amp; Rock Outcrop</rdfs:label>
    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620273"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A tropical open-rock ecosystem characterised by exposed cliff and rock outcrop substrates, minimal soil, extreme microclimate variability, and highly specialised stress-tolerant plant communities with high local endemism.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298985/Tropical_Cliff_Rock_Outcrop_Ecobiome"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620274 -->

