    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620047"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">An earthworks process in which a human reshapes the banks or basin of a pond.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.1016/j.jenvman.2024.120992"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620048 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620048">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620043"/>
        <obo:IAO_0000115 xml:lang="en">An earthworks process in which a human alleviates the compaction of soil.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">soil decompaction process</rdfs:label>
    </Class>
