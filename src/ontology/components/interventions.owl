    <Class rdf:about="https://w3id.org/elmo/elmo_3620858">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620849"/>
        <obo:IAO_0000115 xml:lang="en">A change to the grazing regime in which a human alters the frequency, timing or intensity of grazing.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
