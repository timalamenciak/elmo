AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3620631> "moss layer transfer process"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#broadMatch> <https://w3id.org/elmo/elmo_3620631> <https://w3id.org/elmo/cas/2.3>)
AnnotationAssertion(<https://w3id.org/elmo/property/hasCASCode> <https://w3id.org/elmo/elmo_3620631> "2.3")
