SubClassOf(<https://w3id.org/elmo/elmo_3621027> <https://w3id.org/elmo/elmo_3620501>)

# Class: <https://w3id.org/elmo/elmo_3621028> (seed ball application process)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3621028> "A seeding process in which a human distributes seeds encased in a ball of clay or organic material. Seed balls protect seeds from desiccation and predation and can be dispersed by hand, slingshot, or aerial drop into areas that are difficult to access."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000116> <https://w3id.org/elmo/elmo_3621028> "Added following Delphi survey recommendations."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#created_by> <https://w3id.org/elmo/elmo_3621028> <https://orcid.org/0000-0002-1296-2528>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#creation_date> <https://w3id.org/elmo/elmo_3621028> "2026-03-18T00:00:00Z"^^xsd:dateTime)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3621028> "seed pellet application"@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3621028> "seedbomb application"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3621028> "seed ball application process"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#broadMatch> <https://w3id.org/elmo/elmo_3621028> <https://w3id.org/elmo/cas/2.3>)
