        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620050"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">An earthworks process in which a human deeply breaks up and overturns soil and vegetation.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.1007/s12224-024-09448-7"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620052 -->

