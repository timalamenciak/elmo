AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3621024> "tile drain installation process"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#broadMatch> <https://w3id.org/elmo/elmo_3621024> <https://w3id.org/elmo/cas/2.3>)
