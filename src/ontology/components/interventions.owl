        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620600"/>
        <obo:IAO_0000115 xml:lang="en">A biological ecosystem management process in which a human creates an artificial reef out of materials with the goal of attracting coral.</obo:IAO_0000115>
