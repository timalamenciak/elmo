SubClassOf(<https://w3id.org/elmo/elmo_3621028> <https://w3id.org/elmo/elmo_3620609>)

# Class: <https://w3id.org/elmo/elmo_3621029> (hay transfer process)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3621029> "A plant material transfer process in which a human cuts hay from a species-rich donor site and spreads it on a receptor restoration site in order to introduce plant propagules and associated invertebrates."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000116> <https://w3id.org/elmo/elmo_3621029> "Added following Delphi survey recommendations."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#created_by> <https://w3id.org/elmo/elmo_3621029> <https://orcid.org/0000-0002-1296-2528>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#creation_date> <https://w3id.org/elmo/elmo_3621029> "2026-03-18T00:00:00Z"^^xsd:dateTime)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3621029> "green hay transfer"@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3621029> "hay strewing"@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <https://w3id.org/elmo/elmo_3621029> "brush harvesting"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3621029> "hay transfer process"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#broadMatch> <https://w3id.org/elmo/elmo_3621029> <https://w3id.org/elmo/cas/2.3>)
AnnotationAssertion(<https://w3id.org/elmo/property/hasCASCode> <https://w3id.org/elmo/elmo_3621029> "2.3")
SubClassOf(<https://w3id.org/elmo/elmo_3621029> <https://w3id.org/elmo/elmo_3620630>)

# Class: <https://w3id.org/elmo/elmo_3621030> (sod transfer process)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3621030> "A plant material transfer process in which a human moves intact blocks of vegetation and soil from a donor site to a receptor restoration site in order to introduce plant communities and associated soil biota."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000116> <https://w3id.org/elmo/elmo_3621030> "Added following Delphi survey recommendations."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#created_by> <https://w3id.org/elmo/elmo_3621030> <https://orcid.org/0000-0002-1296-2528>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#creation_date> <https://w3id.org/elmo/elmo_3621030> "2026-03-18T00:00:00Z"^^xsd:dateTime)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3621030> "sod transplant process"@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3621030> "turf transplant process"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3621030> "sod transfer process"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#broadMatch> <https://w3id.org/elmo/elmo_3621030> <https://w3id.org/elmo/cas/2.3>)
