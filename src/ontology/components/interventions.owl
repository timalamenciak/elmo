AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#creation_date> <https://w3id.org/elmo/elmo_3621034> "2026-03-18T00:00:00Z"^^xsd:dateTime)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <https://w3id.org/elmo/elmo_3621034> "local bylaw process"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3621034> "municipal legislation process"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#broadMatch> <https://w3id.org/elmo/elmo_3621034> <https://w3id.org/elmo/cas/5.1.3>)
AnnotationAssertion(<https://w3id.org/elmo/property/hasCASCode> <https://w3id.org/elmo/elmo_3621034> "5.1.3")
