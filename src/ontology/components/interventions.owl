    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620622"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A seed treatment process in which some chemical is applied to some seed in order to enhance germination.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.1111/rec.13210"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620623 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620623">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620600"/>
        <obo:IAO_0000115 xml:lang="en">A biological ecosystem management process in which a human uses biological means to reduce or increase a population of fauna.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">biological fauna control process</rdfs:label>
    </Class>
    


    <!-- https://w3id.org/elmo/elmo_3620624 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620624">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620600"/>
        <obo:IAO_0000115 xml:lang="en">A biological ecosystem management process in which a human facilitates the breeding of fauna, rears the young for a period of time and releases them in some environment.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">captive breeding and release process</rdfs:label>
    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620624"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A biological ecosystem management process in which a human facilitates the breeding of fauna, rears the young for a period of time and releases them in some environment.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.1111/j.1523-1739.2008.00967.x"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620625 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620625">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620624"/>
        <obo:IAO_0000115 xml:lang="en">A captive breeding and release process in which a human collects eggs and relocates them to a safe environment, whereupon they are allowed to hatch.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">egg relocation and release process</rdfs:label>
    </Class>
    


    <!-- https://w3id.org/elmo/elmo_3620626 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620626">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620625"/>
        <obo:IAO_0000115 xml:lang="en">An egg relocation and release process in which a human collects eggs and relocates them into an incubator, whereupon they are allowed to hatch and released into some environment.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">egg incubation and release process</rdfs:label>
    </Class>
    


    <!-- https://w3id.org/elmo/elmo_3620627 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620627">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620624"/>
        <obo:IAO_0000115 xml:lang="en">A captive breeding and release process in which a human captures young fauna, rears them into adulthood and releases them into some environment.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">young capture, rearing and release</rdfs:label>
    </Class>
    


    <!-- https://w3id.org/elmo/elmo_3620628 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620628">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620600"/>
        <obo:IAO_0000115 xml:lang="en">A biological ecosystem management process in which a human provides supplemental water sources for wild fauna in areas where natural water availability is limited. Examples include constructing artificial ponds, guzzlers, or placing temporary water troughs for wildlife during drought. Distinct from irrigation process, which provides water to plants.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">supplemental water process</rdfs:label>
    </Class>
    


    <!-- https://w3id.org/elmo/elmo_3620629 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620629">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620600"/>
        <obo:IAO_0000115 xml:lang="en">A biological ecosystem management process in which a human provides supplemental food to fauna.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">supplemental feeding process</rdfs:label>
    </Class>
    


    <!-- https://w3id.org/elmo/elmo_3620630 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620630">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620600"/>
        <obo:IAO_0000115 xml:lang="en">A biological ecosystem management process in which a human transfers plant material from some area to another.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">plant material transfer process</rdfs:label>
    </Class>
    


    <!-- https://w3id.org/elmo/elmo_3620631 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620631">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620630"/>
        <obo:IAO_0000115 xml:lang="en">A plant material transfer process in which a human collects material from the moss layer (approximately the top 10 cm) of a donor peatland and transfers it to a restoration site to reintroduce peatland-forming mosses and associated species.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Hydrological restoration steps (e.g. blocking drainage ditches) that may precede or accompany moss transfer should be represented as separate processes under mechanical hydrological alteration process.</obo:IAO_0000116>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">moss layer transfer process</rdfs:label>
    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620631"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A plant material transfer process in which a human collects material from the moss layer (approximately the top 10 cm) of a donor peatland and transfers it to a restoration site to reintroduce peatland-forming mosses and associated species.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.1016/j.ecoleng.2014.03.051"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620632 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620632">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620600"/>
        <obo:IAO_0000115 xml:lang="en">A biological ecosystem management process in which a human transfers soil from one area to another.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">soil transfer process</rdfs:label>
    </Class>
    


    <!-- https://w3id.org/elmo/elmo_3620633 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620633">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620623"/>
        <obo:IAO_0000115 xml:lang="en">A biological fauna control process in which a human renders some fauna sterile in order to reduce their population.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">fauna sterilization process</rdfs:label>
    </Class>
    


    <!-- https://w3id.org/elmo/elmo_3620634 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620634">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620623"/>
        <obo:IAO_0000115 xml:lang="en">A biological fauna control process in which a human destroys the eggs of some fauna (e.g. oiling goose eggs).</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">egg destruction process</rdfs:label>
    </Class>
    


    <!-- https://w3id.org/elmo/elmo_3620635 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620635">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620623"/>
        <obo:IAO_0000115 xml:lang="en">A biological ecosystem management process in which a human implements measures to deter fauna from establishing nest sites in a given area.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">nest establishment deterrence process</rdfs:label>
    </Class>
    


    <!-- https://w3id.org/elmo/elmo_3620636 -->

