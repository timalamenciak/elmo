AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#creation_date> <https://w3id.org/elmo/elmo_3621059> "2026-07-07"^^xsd:dateTime)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3621059> "peat harvesting"@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3621059> "peat mining"@en)
AnnotationAssertion(rdfs:comment <https://w3id.org/elmo/elmo_3621059> "Represents a disturbance driver that typically necessitates subsequent restoration interventions such as peatland rewetting process (ELMO:3620646) and moss layer transfer process (ELMO:3620631)."@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3621059> "peat extraction process"@en)
