        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620048"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">An earthworks process in which a human alleviates the compaction of soil.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.1111/j.1526-100X.2008.00477.x"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620049 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620049">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620048"/>
        <obo:IAO_0000115 xml:lang="en">An earthworks process in which a human breaks up the soil, and sometimes adds organic matter.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <oboInOwl:hasNarrowSynonym xml:lang="en">soil ripping process</oboInOwl:hasNarrowSynonym>
        <rdfs:label xml:lang="en">tilling process</rdfs:label>
    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620049"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">An earthworks process in which a human breaks up the soil, and sometimes adds organic matter.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.1111/j.1526-100X.1995.tb00096.x"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620050 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620050">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620048"/>
        <obo:IAO_0000115 xml:lang="en">An earthworks process in which a human deeply breaks up and overturns soil and vegetation.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
