    <!-- https://w3id.org/elmo/elmo_3620646 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620646">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620033"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical hydrological alteration process in which a human raises the water table of a degraded peatland or wetland, typically by blocking drainage ditches or installing water control structures, with the goal of restoring wetland function and hydrology.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Reclassified from biological ecosystem management process to mechanical hydrological alteration process, as this intervention is fundamentally hydrological in nature.</obo:IAO_0000116>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">peatland rewetting process</rdfs:label>
    </Class>
    <Axiom>
        <annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620646"/>
        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A mechanical hydrological alteration process in which a human raises the water table of a degraded peatland or wetland, typically by blocking drainage ditches or installing water control structures, with the goal of restoring wetland function and hydrology.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.1007/s11027-023-10046-9"/>
    </Axiom>
    


