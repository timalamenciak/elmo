        <annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <annotatedTarget xml:lang="en">A seed treatment process in which light is applied to seeds in order to enhance germination.</annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.1111/rec.13210"/>
    </Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620622 -->

    <Class rdf:about="https://w3id.org/elmo/elmo_3620622">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620616"/>
        <obo:IAO_0000115 xml:lang="en">A seed treatment process in which some chemical is applied to some seed in order to enhance germination.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
