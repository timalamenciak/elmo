AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3622706> "The proportion of seedlings or introduced propagules that successfully transition from initial emergence to persistence as established plants at a restoration site over a specified period."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#created_by> <https://w3id.org/elmo/elmo_3622706> <https://orcid.org/0000-0002-1296-2528>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#creation_date> <https://w3id.org/elmo/elmo_3622706> "2026-07-07T00:00:00Z"^^xsd:dateTime)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3622706> "seedling establishment"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3622706> "seedling establishment rate"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3622706> <https://w3id.org/elmo/elmo_3622704>)

# Class: <https://w3id.org/elmo/elmo_3622707> (seedling growth rate)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3622707> "The rate of increase in size (height, basal diameter, or dry mass) of individual seedlings over a specified time period at a restoration site."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#created_by> <https://w3id.org/elmo/elmo_3622707> <https://orcid.org/0000-0002-1296-2528>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#creation_date> <https://w3id.org/elmo/elmo_3622707> "2026-07-07T00:00:00Z"^^xsd:dateTime)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3622707> "seedling growth"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3622707> "seedling growth rate"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3622707> <https://w3id.org/elmo/elmo_3622704>)

# Class: <https://w3id.org/elmo/elmo_3622708> (seedling emergence rate)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3622708> "The rate at which seeds germinate and produce seedlings that emerge above the soil surface at a site over a specified period."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#created_by> <https://w3id.org/elmo/elmo_3622708> <https://orcid.org/0000-0002-1296-2528>)
