AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3622804> "habitat loss"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3622804> "habitat loss area"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3622804> <https://w3id.org/elmo/elmo_3622600>)

# Class: <https://w3id.org/elmo/elmo_3622805> (seismic line density)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3622805> "The total linear extent or area of seismic exploration corridors — linear clearings cut through forested terrain during geophysical surveys for oil and gas exploration — per unit landscape area at a site."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#created_by> <https://w3id.org/elmo/elmo_3622805> <https://orcid.org/0000-0002-1296-2528>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#creation_date> <https://w3id.org/elmo/elmo_3622805> "2026-07-07T00:00:00Z"^^xsd:dateTime)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3622805> "seismic line coverage"@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3622805> "seismic lines"@en)
AnnotationAssertion(rdfs:comment <https://w3id.org/elmo/elmo_3622805> "Seismic lines are a key disturbance type in Canadian boreal forest and peatland restoration, particularly in Alberta."@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3622805> "seismic line density"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3622805> <https://w3id.org/elmo/elmo_3622600>)


