# Class: <https://w3id.org/elmo/elmo_3622000> (environmental variable)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3622000> "A quality of an environmental system that reflects a physical, chemical, or hydrological condition of the abiotic environment and that can be measured or observed."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#created_by> <https://w3id.org/elmo/elmo_3622000> <https://orcid.org/0000-0002-1296-2528>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#creation_date> <https://w3id.org/elmo/elmo_3622000> "2026-07-05T00:00:00Z"^^xsd:dateTime)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3622000> "environmental variable"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3622000> <http://purl.obolibrary.org/obo/BFO_0000019>)

# Class: <https://w3id.org/elmo/elmo_3622001> (climatic and meteorological variable)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3622001> "An environmental variable that describes the state of the atmosphere at or near a site over a given period, such as temperature, precipitation, humidity, or radiation."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#created_by> <https://w3id.org/elmo/elmo_3622001> <https://orcid.org/0000-0002-1296-2528>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#creation_date> <https://w3id.org/elmo/elmo_3622001> "2026-07-05T00:00:00Z"^^xsd:dateTime)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3622001> "climatic and meteorological variable"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3622001> <https://w3id.org/elmo/elmo_3622000>)

# Class: <https://w3id.org/elmo/elmo_3622002> (air temperature)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3622002> "The temperature of the ambient air at a specified height above the ground surface at a site."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#created_by> <https://w3id.org/elmo/elmo_3622002> <https://orcid.org/0000-0002-1296-2528>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#creation_date> <https://w3id.org/elmo/elmo_3622002> "2026-07-05T00:00:00Z"^^xsd:dateTime)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3622002> "ambient temperature"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3622002> "air temperature"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#exactMatch> <https://w3id.org/elmo/elmo_3622002> <http://purl.obolibrary.org/obo/ENVO_09200001>)
SubClassOf(<https://w3id.org/elmo/elmo_3622002> <https://w3id.org/elmo/elmo_3622001>)

# Class: <https://w3id.org/elmo/elmo_3622003> (precipitation amount)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3622003> "The depth of water (from rain, snow, hail, or other forms) that reaches the ground surface at a site over a specified period."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#created_by> <https://w3id.org/elmo/elmo_3622003> <https://orcid.org/0000-0002-1296-2528>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#creation_date> <https://w3id.org/elmo/elmo_3622003> "2026-07-05T00:00:00Z"^^xsd:dateTime)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3622003> "rainfall amount"@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <https://w3id.org/elmo/elmo_3622003> "precipitation"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3622003> "precipitation amount"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#exactMatch> <https://w3id.org/elmo/elmo_3622003> <http://purl.obolibrary.org/obo/ENVO_01001363>)
SubClassOf(<https://w3id.org/elmo/elmo_3622003> <https://w3id.org/elmo/elmo_3622001>)

# Class: <https://w3id.org/elmo/elmo_3622004> (relative humidity)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3622004> "The ratio of the amount of water vapor actually present in the air to the amount that the air could hold at saturation at the same temperature, expressed as a percentage."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#created_by> <https://w3id.org/elmo/elmo_3622004> <https://orcid.org/0000-0002-1296-2528>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#creation_date> <https://w3id.org/elmo/elmo_3622004> "2026-07-05T00:00:00Z"^^xsd:dateTime)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3622004> "RH"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3622004> "relative humidity"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3622004> <https://w3id.org/elmo/elmo_3622001>)

# Class: <https://w3id.org/elmo/elmo_3622005> (wind speed)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3622005> "The rate of horizontal air movement at a specified height above the ground surface at a site."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#created_by> <https://w3id.org/elmo/elmo_3622005> <https://orcid.org/0000-0002-1296-2528>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#creation_date> <https://w3id.org/elmo/elmo_3622005> "2026-07-05T00:00:00Z"^^xsd:dateTime)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3622005> "wind velocity"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3622005> "wind speed"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#exactMatch> <https://w3id.org/elmo/elmo_3622005> <http://purl.obolibrary.org/obo/ENVO_01001362>)
SubClassOf(<https://w3id.org/elmo/elmo_3622005> <https://w3id.org/elmo/elmo_3622001>)

# Class: <https://w3id.org/elmo/elmo_3622006> (photosynthetically active radiation)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3622006> "The amount of solar radiation in the 400-700 nm waveband reaching a site, which is the spectral range used by plants for photosynthesis."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#created_by> <https://w3id.org/elmo/elmo_3622006> <https://orcid.org/0000-0002-1296-2528>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#creation_date> <https://w3id.org/elmo/elmo_3622006> "2026-07-05T00:00:00Z"^^xsd:dateTime)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3622006> "PAR"@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <https://w3id.org/elmo/elmo_3622006> "solar radiation"@en)
AnnotationAssertion(rdfs:comment <https://w3id.org/elmo/elmo_3622006> "Often reported as an instantaneous flux density (micromol photons per square metre per second) or integrated as daily light integral."@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3622006> "photosynthetically active radiation"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#exactMatch> <https://w3id.org/elmo/elmo_3622006> <http://purl.obolibrary.org/obo/ENVO_01001864>)
SubClassOf(<https://w3id.org/elmo/elmo_3622006> <https://w3id.org/elmo/elmo_3622001>)

# Class: <https://w3id.org/elmo/elmo_3622007> (growing degree days)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3622007> "A cumulative measure of heat accumulation calculated from the amount by which daily mean air temperature exceeds a specified base temperature over a growing season, used to predict plant development timing."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#created_by> <https://w3id.org/elmo/elmo_3622007> <https://orcid.org/0000-0002-1296-2528>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#creation_date> <https://w3id.org/elmo/elmo_3622007> "2026-07-05T00:00:00Z"^^xsd:dateTime)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <https://w3id.org/elmo/elmo_3622007> "heat units"@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3622007> "GDD"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3622007> "growing degree days"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3622007> <https://w3id.org/elmo/elmo_3622001>)

# Class: <https://w3id.org/elmo/elmo_3622100> (soil variable)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3622100> "An environmental variable that describes a physical, chemical, or biological property of the soil at a site."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#created_by> <https://w3id.org/elmo/elmo_3622100> <https://orcid.org/0000-0002-1296-2528>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#creation_date> <https://w3id.org/elmo/elmo_3622100> "2026-07-05T00:00:00Z"^^xsd:dateTime)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3622100> "soil variable"@en)
SubClassOf(<https://w3id.org/elmo/elmo_3622100> <https://w3id.org/elmo/elmo_3622000>)

# Class: <https://w3id.org/elmo/elmo_3622101> (soil pH)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3622101> "A measure of the acidity or alkalinity of a soil, expressed as the negative logarithm of the hydrogen ion activity in a soil-water or soil-solution mixture."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#created_by> <https://w3id.org/elmo/elmo_3622101> <https://orcid.org/0000-0002-1296-2528>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#creation_date> <https://w3id.org/elmo/elmo_3622101> "2026-07-05T00:00:00Z"^^xsd:dateTime)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <https://w3id.org/elmo/elmo_3622101> "soil reaction"@en)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3622101> "soil pH"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#exactMatch> <https://w3id.org/elmo/elmo_3622101> <http://purl.obolibrary.org/obo/ENVO_09200010>)
SubClassOf(<https://w3id.org/elmo/elmo_3622101> <https://w3id.org/elmo/elmo_3622100>)

# Class: <https://w3id.org/elmo/elmo_3622102> (soil temperature)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3622102> "The temperature of the soil at a specified depth below the ground surface."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#created_by> <https://w3id.org/elmo/elmo_3622102> <https://orcid.org/0000-0002-1296-2528>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#creation_date> <https://w3id.org/elmo/elmo_3622102> "2026-07-05T00:00:00Z"^^xsd:dateTime)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/elmo_3622102> "soil temperature"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#exactMatch> <https://w3id.org/elmo/elmo_3622102> <http://purl.obolibrary.org/obo/ENVO_09200012>)
SubClassOf(<https://w3id.org/elmo/elmo_3622102> <https://w3id.org/elmo/elmo_3622100>)

# Class: <https://w3id.org/elmo/elmo_3622105> (soil penetration resistance)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/elmo/elmo_3622105> "The force per unit area required to push a probe or cone into the soil to a specified depth, used as a field indicator of soil compaction."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#created_by> <https://w3id.org/elmo/elmo_3622105> <https://orcid.org/0000-0002-1296-2528>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#creation_date> <https://w3id.org/elmo/elmo_3622105> "2026-07-05T00:00:00Z"^^xsd:dateTime)
