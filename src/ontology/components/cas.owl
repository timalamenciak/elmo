Prefix(cas:=<https://w3id.org/elmo/cas/>)
Prefix(dce:=<http://purl.org/dc/elements/1.1/>)
Prefix(obo:=<http://purl.obolibrary.org/obo/>)
Prefix(owl:=<http://www.w3.org/2002/07/owl#>)
Prefix(rdf:=<http://www.w3.org/1999/02/22-rdf-syntax-ns#>)
Prefix(xml:=<http://www.w3.org/XML/1998/namespace>)
Prefix(xsd:=<http://www.w3.org/2001/XMLSchema#>)
Prefix(rdfs:=<http://www.w3.org/2000/01/rdf-schema#>)


Ontology(<https://w3id.org/elmo/elmo/components/cas.owl>

Annotation(dce:title "IUCN Conservation Actions Classification Scheme v2.0")
Annotation(dce:source <https://www.iucnredlist.org/resources/conservation-actions>)


############################
#   Annotation Properties
############################

Declaration(AnnotationProperty(obo:IAO_0000115))
Declaration(AnnotationProperty(dce:source))
Declaration(AnnotationProperty(dce:title))


############################
#   Classes
############################

# ─────────────────────────────────────────
# Top class: Conservation Action
# ─────────────────────────────────────────

Declaration(Class(cas:ConservationAction))
SubClassOf(cas:ConservationAction obo:BFO_0000015)
AnnotationAssertion(rdfs:label cas:ConservationAction "conservation action"@en)
AnnotationAssertion(obo:IAO_0000115 cas:ConservationAction "A process undertaken by humans or organizations to protect, manage, or restore biodiversity and ecosystem services."@en)
AnnotationAssertion(dce:source cas:ConservationAction <https://www.iucnredlist.org/resources/conservation-actions>)


# ─────────────────────────────────────────
# 1. Land/water protection
# ─────────────────────────────────────────

Declaration(Class(<https://w3id.org/elmo/cas/1>))
SubClassOf(<https://w3id.org/elmo/cas/1> cas:ConservationAction)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/1> "Land/water protection"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/1> "A conservation action in which land or water areas are formally or voluntarily protected from harmful activities to conserve biodiversity."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/1> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/1.1>))
SubClassOf(<https://w3id.org/elmo/cas/1.1> <https://w3id.org/elmo/cas/1>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/1.1> "Site/area protection"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/1.1> "A land/water protection action in which a specific site or area is formally designated for conservation through legal or institutional mechanisms."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/1.1> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/1.2>))
SubClassOf(<https://w3id.org/elmo/cas/1.2> <https://w3id.org/elmo/cas/1>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/1.2> "Resource & habitat protection"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/1.2> "A land/water protection action in which specific natural resources or habitats are legally or institutionally safeguarded from exploitation or degradation."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/1.2> <https://www.iucnredlist.org/resources/conservation-actions>)


# ─────────────────────────────────────────
# 2. Land/water management
# ─────────────────────────────────────────

Declaration(Class(<https://w3id.org/elmo/cas/2>))
SubClassOf(<https://w3id.org/elmo/cas/2> cas:ConservationAction)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/2> "Land/water management"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/2> "A conservation action in which land or water areas are actively managed to maintain or improve their biodiversity values and ecological function."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/2> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/2.1>))
SubClassOf(<https://w3id.org/elmo/cas/2.1> <https://w3id.org/elmo/cas/2>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/2.1> "Site/area management"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/2.1> "A land/water management action in which a specific site or area is actively managed using on-the-ground interventions to achieve defined conservation objectives."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/2.1> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/2.2>))
SubClassOf(<https://w3id.org/elmo/cas/2.2> <https://w3id.org/elmo/cas/2>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/2.2> "Invasive/problematic species control"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/2.2> "A land/water management action in which invasive or otherwise problematic species are controlled, suppressed, or eradicated to reduce their negative impacts on native biodiversity."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/2.2> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/2.3>))
SubClassOf(<https://w3id.org/elmo/cas/2.3> <https://w3id.org/elmo/cas/2>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/2.3> "Habitat & natural process restoration"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/2.3> "A land/water management action in which degraded habitats or disrupted natural ecological processes are actively restored toward a more natural condition."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/2.3> <https://www.iucnredlist.org/resources/conservation-actions>)


# ─────────────────────────────────────────
# 3. Species management
# ─────────────────────────────────────────

Declaration(Class(<https://w3id.org/elmo/cas/3>))
SubClassOf(<https://w3id.org/elmo/cas/3> cas:ConservationAction)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/3> "Species management"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/3> "A conservation action directed at managing, recovering, or maintaining populations of one or more species."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/3> <https://www.iucnredlist.org/resources/conservation-actions>)

# 3.1 Species management (sub-category)

Declaration(Class(<https://w3id.org/elmo/cas/3.1>))
SubClassOf(<https://w3id.org/elmo/cas/3.1> <https://w3id.org/elmo/cas/3>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/3.1> "Species management"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/3.1> "A species management action in which the population size, structure, or dynamics of a species are directly regulated through human intervention."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/3.1> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/3.1.1>))
SubClassOf(<https://w3id.org/elmo/cas/3.1.1> <https://w3id.org/elmo/cas/3.1>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/3.1.1> "Harvest management"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/3.1.1> "A species management action in which the harvest or take of a species is regulated or controlled to maintain sustainable population levels."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/3.1.1> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/3.1.2>))
SubClassOf(<https://w3id.org/elmo/cas/3.1.2> <https://w3id.org/elmo/cas/3.1>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/3.1.2> "Trade management"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/3.1.2> "A species management action in which the trade in a species or its products is regulated or controlled to prevent unsustainable exploitation."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/3.1.2> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/3.1.3>))
SubClassOf(<https://w3id.org/elmo/cas/3.1.3> <https://w3id.org/elmo/cas/3.1>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/3.1.3> "Limiting population growth"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/3.1.3> "A species management action in which the growth of a species population is actively limited, typically to reduce overabundance or human-wildlife conflict."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/3.1.3> <https://www.iucnredlist.org/resources/conservation-actions>)

# 3.2 Species recovery

Declaration(Class(<https://w3id.org/elmo/cas/3.2>))
SubClassOf(<https://w3id.org/elmo/cas/3.2> <https://w3id.org/elmo/cas/3>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/3.2> "Species recovery"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/3.2> "A species management action in which active interventions are carried out to increase the size or improve the conservation status of a threatened species population."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/3.2> <https://www.iucnredlist.org/resources/conservation-actions>)

# 3.3 Species re-introduction

Declaration(Class(<https://w3id.org/elmo/cas/3.3>))
SubClassOf(<https://w3id.org/elmo/cas/3.3> <https://w3id.org/elmo/cas/3>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/3.3> "Species re-introduction"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/3.3> "A species management action in which individuals of a species are deliberately moved to and released at a location where the species has been extirpated or was previously absent."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/3.3> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/3.3.1>))
SubClassOf(<https://w3id.org/elmo/cas/3.3.1> <https://w3id.org/elmo/cas/3.3>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/3.3.1> "Reintroduction"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/3.3.1> "A species re-introduction action in which individuals are released into a site within the species' historical native range where the species no longer occurs."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/3.3.1> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/3.3.2>))
SubClassOf(<https://w3id.org/elmo/cas/3.3.2> <https://w3id.org/elmo/cas/3.3>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/3.3.2> "Benign introduction"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/3.3.2> "A species re-introduction action in which individuals are intentionally moved and released at a location outside the species' historical range to fulfil an ecological or conservation function."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/3.3.2> <https://www.iucnredlist.org/resources/conservation-actions>)

# 3.4 Ex-situ conservation

Declaration(Class(<https://w3id.org/elmo/cas/3.4>))
SubClassOf(<https://w3id.org/elmo/cas/3.4> <https://w3id.org/elmo/cas/3>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/3.4> "Ex-situ conservation"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/3.4> "A species management action in which individuals, reproductive material, or genetic material are maintained outside their natural habitat for the purpose of conserving biodiversity."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/3.4> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/3.4.1>))
SubClassOf(<https://w3id.org/elmo/cas/3.4.1> <https://w3id.org/elmo/cas/3.4>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/3.4.1> "Captive breeding/artificial propagation"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/3.4.1> "An ex-situ conservation action in which animals or plants are bred or propagated under controlled conditions to maintain or supplement wild populations."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/3.4.1> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/3.4.2>))
SubClassOf(<https://w3id.org/elmo/cas/3.4.2> <https://w3id.org/elmo/cas/3.4>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/3.4.2> "Genome resource bank"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/3.4.2> "An ex-situ conservation action in which genetic material such as gametes, embryos, or DNA samples are collected and stored for the long-term preservation of biodiversity."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/3.4.2> <https://www.iucnredlist.org/resources/conservation-actions>)


# ─────────────────────────────────────────
# 4. Education & awareness
# ─────────────────────────────────────────

Declaration(Class(<https://w3id.org/elmo/cas/4>))
SubClassOf(<https://w3id.org/elmo/cas/4> cas:ConservationAction)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/4> "Education & awareness"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/4> "A conservation action in which knowledge, skills, or awareness related to biodiversity and its conservation are communicated to target audiences."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/4> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/4.1>))
SubClassOf(<https://w3id.org/elmo/cas/4.1> <https://w3id.org/elmo/cas/4>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/4.1> "Formal education"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/4.1> "An education and awareness action in which structured, accredited conservation knowledge and skills are delivered through schools, universities, or other formal educational institutions."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/4.1> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/4.2>))
SubClassOf(<https://w3id.org/elmo/cas/4.2> <https://w3id.org/elmo/cas/4>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/4.2> "Training"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/4.2> "An education and awareness action in which practical conservation skills or knowledge are provided to specific groups such as practitioners, rangers, or resource managers."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/4.2> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/4.3>))
SubClassOf(<https://w3id.org/elmo/cas/4.3> <https://w3id.org/elmo/cas/4>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/4.3> "Awareness & communications"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/4.3> "An education and awareness action in which information about biodiversity threats and conservation solutions is disseminated to the general public or specific audiences through media or outreach."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/4.3> <https://www.iucnredlist.org/resources/conservation-actions>)


# ─────────────────────────────────────────
# 5. Law & policy
# ─────────────────────────────────────────

Declaration(Class(<https://w3id.org/elmo/cas/5>))
SubClassOf(<https://w3id.org/elmo/cas/5> cas:ConservationAction)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/5> "Law & policy"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/5> "A conservation action in which legal instruments, policies, or regulations are developed, strengthened, or enforced to advance biodiversity conservation."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/5> <https://www.iucnredlist.org/resources/conservation-actions>)

# 5.1 Legislation

Declaration(Class(<https://w3id.org/elmo/cas/5.1>))
SubClassOf(<https://w3id.org/elmo/cas/5.1> <https://w3id.org/elmo/cas/5>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/5.1> "Legislation"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/5.1> "A law and policy action in which formal laws or statutes are developed, amended, or repealed to provide legal protection or support for biodiversity conservation."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/5.1> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/5.1.1>))
SubClassOf(<https://w3id.org/elmo/cas/5.1.1> <https://w3id.org/elmo/cas/5.1>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/5.1.1> "International level"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/5.1.1> "A legislation action in which international treaties, conventions, or multilateral agreements are developed or ratified to protect biodiversity at the global scale."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/5.1.1> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/5.1.2>))
SubClassOf(<https://w3id.org/elmo/cas/5.1.2> <https://w3id.org/elmo/cas/5.1>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/5.1.2> "National level"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/5.1.2> "A legislation action in which national laws or statutes are developed, amended, or repealed to protect biodiversity within a country's jurisdiction."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/5.1.2> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/5.1.3>))
SubClassOf(<https://w3id.org/elmo/cas/5.1.3> <https://w3id.org/elmo/cas/5.1>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/5.1.3> "Sub-national level"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/5.1.3> "A legislation action in which sub-national laws or regulations such as provincial, state, or municipal statutes are developed or amended to protect biodiversity."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/5.1.3> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/5.1.4>))
SubClassOf(<https://w3id.org/elmo/cas/5.1.4> <https://w3id.org/elmo/cas/5.1>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/5.1.4> "Scale unspecified"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/5.1.4> "A legislation action in which laws or statutes protecting biodiversity are developed or amended at a jurisdictional scale that is not specified."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/5.1.4> <https://www.iucnredlist.org/resources/conservation-actions>)

# 5.2 Policies and regulations

Declaration(Class(<https://w3id.org/elmo/cas/5.2>))
SubClassOf(<https://w3id.org/elmo/cas/5.2> <https://w3id.org/elmo/cas/5>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/5.2> "Policies and regulations"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/5.2> "A law and policy action in which non-statutory policies, administrative rules, or regulations are developed or strengthened to promote biodiversity conservation."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/5.2> <https://www.iucnredlist.org/resources/conservation-actions>)

# 5.3 Private sector standards & codes

Declaration(Class(<https://w3id.org/elmo/cas/5.3>))
SubClassOf(<https://w3id.org/elmo/cas/5.3> <https://w3id.org/elmo/cas/5>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/5.3> "Private sector standards & codes"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/5.3> "A law and policy action in which voluntary or mandatory standards and codes of practice are developed for the private sector to reduce its negative impacts on biodiversity."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/5.3> <https://www.iucnredlist.org/resources/conservation-actions>)

# 5.4 Compliance and enforcement

Declaration(Class(<https://w3id.org/elmo/cas/5.4>))
SubClassOf(<https://w3id.org/elmo/cas/5.4> <https://w3id.org/elmo/cas/5>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/5.4> "Compliance and enforcement"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/5.4> "A law and policy action in which existing laws, regulations, or standards protecting biodiversity are enforced and adherence is actively monitored."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/5.4> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/5.4.1>))
SubClassOf(<https://w3id.org/elmo/cas/5.4.1> <https://w3id.org/elmo/cas/5.4>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/5.4.1> "International level"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/5.4.1> "A compliance and enforcement action carried out through international bodies or mechanisms to ensure adherence to biodiversity-related conventions and multilateral agreements."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/5.4.1> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/5.4.2>))
SubClassOf(<https://w3id.org/elmo/cas/5.4.2> <https://w3id.org/elmo/cas/5.4>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/5.4.2> "National level"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/5.4.2> "A compliance and enforcement action carried out by national authorities to ensure adherence to biodiversity-related laws and regulations within a country."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/5.4.2> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/5.4.3>))
SubClassOf(<https://w3id.org/elmo/cas/5.4.3> <https://w3id.org/elmo/cas/5.4>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/5.4.3> "Sub-national level"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/5.4.3> "A compliance and enforcement action carried out by sub-national authorities such as provincial or municipal agencies to ensure adherence to biodiversity-related laws."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/5.4.3> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/5.4.4>))
SubClassOf(<https://w3id.org/elmo/cas/5.4.4> <https://w3id.org/elmo/cas/5.4>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/5.4.4> "Scale unspecified"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/5.4.4> "A compliance and enforcement action carried out to ensure adherence to biodiversity-related laws or regulations at a jurisdictional scale that is not specified."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/5.4.4> <https://www.iucnredlist.org/resources/conservation-actions>)


# ─────────────────────────────────────────
# 6. Livelihood, economic & other incentives
# ─────────────────────────────────────────

Declaration(Class(<https://w3id.org/elmo/cas/6>))
SubClassOf(<https://w3id.org/elmo/cas/6> cas:ConservationAction)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/6> "Livelihood, economic & other incentives"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/6> "A conservation action in which economic, livelihood, or social incentives are used to encourage behaviours or practices that benefit biodiversity conservation."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/6> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/6.1>))
SubClassOf(<https://w3id.org/elmo/cas/6.1> <https://w3id.org/elmo/cas/6>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/6.1> "Linked enterprises & livelihood alternatives"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/6.1> "A livelihood and economic incentive action in which alternative income sources or enterprises compatible with conservation goals are developed for local communities."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/6.1> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/6.2>))
SubClassOf(<https://w3id.org/elmo/cas/6.2> <https://w3id.org/elmo/cas/6>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/6.2> "Substitution"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/6.2> "A livelihood and economic incentive action in which harmful or unsustainable products, practices, or exploited species are replaced with sustainable alternatives to reduce biodiversity impacts."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/6.2> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/6.3>))
SubClassOf(<https://w3id.org/elmo/cas/6.3> <https://w3id.org/elmo/cas/6>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/6.3> "Market forces"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/6.3> "A livelihood and economic incentive action in which market mechanisms such as eco-certification, sustainable sourcing standards, or consumer demand are harnessed to promote conservation-compatible practices."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/6.3> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/6.4>))
SubClassOf(<https://w3id.org/elmo/cas/6.4> <https://w3id.org/elmo/cas/6>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/6.4> "Conservation payments"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/6.4> "A livelihood and economic incentive action in which direct financial payments or transfers are made to landowners, communities, or individuals in exchange for managing land in a conservation-compatible manner."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/6.4> <https://www.iucnredlist.org/resources/conservation-actions>)

Declaration(Class(<https://w3id.org/elmo/cas/6.5>))
SubClassOf(<https://w3id.org/elmo/cas/6.5> <https://w3id.org/elmo/cas/6>)
AnnotationAssertion(rdfs:label <https://w3id.org/elmo/cas/6.5> "Non-monetary values"@en)
AnnotationAssertion(obo:IAO_0000115 <https://w3id.org/elmo/cas/6.5> "A livelihood and economic incentive action in which the cultural, spiritual, aesthetic, or intrinsic values of biodiversity are recognised and promoted to motivate conservation behaviour."@en)
AnnotationAssertion(dce:source <https://w3id.org/elmo/cas/6.5> <https://www.iucnredlist.org/resources/conservation-actions>)


)
