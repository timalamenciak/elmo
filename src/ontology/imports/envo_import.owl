AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#created_by> "https://orcid.org/0000-0002-9620-2832") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "www.awi.de/internas") <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/ENVO_01001170> "Umweltmaßnahme"@de)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/ENVO_01001170> "environmental management")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/ENVO_01001170> "active ecosystem management process"@en)
