property_value: IAO:0000116 "Definition taken from IUCN GET. Needs to be reformatted for ontology." xsd:string
property_value: IAO:0000116 "Exact synonym with eIVC biome." xsd:string

[Term]
id: elmo:3620209
name: Shrublands and shrubby woodlands biome
def: "The shrublands and shrub-dominated woodlands biome is a biome that includes oligotrophic systems occurring on acidic, sandy soils that are often shallow or skeletal, distributed across al llandmasses outside the polar regions." [https://global-ecosystems.org/explore/biomes/T3]
synonym: "T3 Shrublands and shrubby woodlands biome" EXACT []
is_a: ENVO:01001110 ! ecosystem
property_value: IAO:0000116 "Definition taken from IUCN GET. Needs to be reformatted for ontology." xsd:string

[Term]
id: elmo:3620210
name: Savannas and grasslands biome
def: "The savannas and grasslands biome is a biome that has ecological functions closely linked to a mostly continuous ground layer of grasses that contribute moderate to very high levels of primary productivity driven by strongly seasonal water surplus and deficit cycles." [https://global-ecosystems.org/explore/biomes/T4]
synonym: "T4 Savannas and grasslands biome" EXACT []
is_a: ENVO:01001110 ! ecosystem
property_value: IAO:0000116 "Definition taken from IUCN GET. Needs to be reformatted for ontology." xsd:string

[Term]
id: elmo:3620211
name: Deserts and semi-deserts biome
def: "The deserts and semi-deserts biome is a biome that includes low to very low biomass ecosystems occurring in arid or semi-arid climates, principally associated with the subtropical high-pressure belts and major continental rain shadows." [https://global-ecosystems.org/explore/biomes/T5]
synonym: "Desert & Semi-desert" EXACT []
synonym: "T5" EXACT []
synonym: "T5 Deserts and semi-deserts biome" EXACT []
synonym: "TT5" EXACT []
synonym: "TT5 Desert & Semi-desert" EXACT []
is_a: ENVO:01001110 ! ecosystem
property_value: IAO:0000116 "Definition taken from IUCN GET. Needs to be reformatted for ontology." xsd:string
property_value: IAO:0000116 "Exact synonym with eIVC biome." xsd:string

[Term]
id: elmo:3620212
name: Polar/alpine (cryogenic) biome
def: "the polar/alpine biome is a biome that encompasses the extensive Arctic and Antarctic regions as well as high mountainous areas across all continental land masses, with low or very low primary productivity." [https://global-ecosystems.org/explore/biomes/T6]
synonym: "Polar & Alpine" EXACT []
synonym: "T6" EXACT []
synonym: "T6 Polar/alpine (cryogenic) biome" EXACT []
