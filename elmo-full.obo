[Term]
id: elmo:3620034
name: dam construction process
def: "A mechanical hydrological alteration process in which a human constructs a dam or barrier across a watercourse for ecological restoration purposes, such as to restore a meander sequence or to raise the water table of adjacent wetlands." [doi:10.1093/biosci/biu036]
synonym: "beaver dam analogue" EXACT []
is_a: elmo:3620033 ! mechanical hydrological alteration process
property_value: dcterms:contributor https://orcid.org/0000-0002-4366-3088
property_value: dcterms:contributor https://orcid.org/0000-0003-4817-0423
