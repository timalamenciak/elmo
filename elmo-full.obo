[Term]
id: elmo:3620030
name: predator control process
def: "A mechanical fauna control process in which a human targets predators for removal from the ecosystem." [https://agrilife.org/txwildlifeservices/files/2011/07/PredatorControlforWildlifeMgt.pdf]
is_a: elmo:3620028 ! mechanical fauna control process
property_value: dcterms:contributor https://orcid.org/0000-0002-4366-3088
