created_by: https://orcid.org/0000-0002-1296-2528

[Term]
id: elmo:3620035
name: dam removal process
def: "A mechanical hydrological alteration process in which a human removes a dam or barrier with the goal of altering the hydroperiod of surrounding lands and reconnecting rivers to their floodplains." [doi:10.12952/journal.elementa.000108]
is_a: elmo:3620033 ! mechanical hydrological alteration process
property_value: dcterms:contributor https://orcid.org/0000-0002-4366-3088
property_value: dcterms:contributor https://orcid.org/0000-0003-4817-0423
