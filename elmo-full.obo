created_by: https://orcid.org/0000-0002-1296-2528

[Term]
id: elmo:3620613
name: broadcast seeding process
def: "A seeding process in which a human scatters seeds across a surface at variable density, either by hand or using a mechanical spreader, without placing them at a specific depth." [doi:10.3375/043.038.0504]
is_a: elmo:3620609 ! seeding process
