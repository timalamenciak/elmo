[Term]
id: elmo:3620501
name: chemical application process
def: "A chemical ecosystem management process in which a human applies some chemical to an ecosystem." [doi:10.1016/j.scitotenv.2021.148631]
is_a: elmo:3620500 ! chemical ecosystem management process
property_value: dcterms:contributor https://orcid.org/0000-0002-4366-3088
