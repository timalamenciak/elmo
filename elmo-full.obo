property_value: skos:broadMatch https://w3id.org/elmo/cas/2.3
created_by: https://orcid.org/0000-0002-1296-2528

[Term]
id: elmo:3620028
name: mechanical fauna control process
def: "A mechanical ecosystem management process in which a human controls fauna populations." []
is_a: elmo:3620020 ! mechanical ecosystem management process
property_value: dcterms:contributor https://orcid.org/0000-0002-4366-3088
