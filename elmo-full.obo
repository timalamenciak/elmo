property_value: IAO:0000116 "Definition taken from IUCN GET. Needs to be reformatted for ontology." xsd:string
property_value: IAO:0000116 "Exact synonym with eIVC biome." xsd:string

[Term]
id: elmo:3620208
name: Temperate-boreal forests and woodlands biome
def: "The temperate-boreal forests and woodlands biome is a biome that includes moderate to highly productive tree-dominated systems with a wide range of physiognomic and structural expressions distributed from warm-temperate to boreal latitudes." [https://global-ecosystems.org/explore/biomes/T2]
synonym: "T2" EXACT []
synonym: "T2 Temperate-boreal forests and woodlands biome" EXACT []
synonym: "Temperate-Boreal Forest & Woodland" EXACT []
synonym: "TT2" EXACT []
synonym: "TT2 Temperate-Boreal Forest & Woodland" EXACT []
