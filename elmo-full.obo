created_by: https://orcid.org/0000-0002-1296-2528

[Term]
id: elmo:3620036
name: tile drain decommissioning process
def: "A mechanical hydrological alteration process in which a human decommissions subterranean tile drains by collapsing them in situ or by excavating and removing them, in order to reduce drainage and restore wetland hydroperiod." []
synonym: "drain removal process" EXACT []
synonym: "tile drain crushing process" EXACT []
synonym: "tile drain removal process" EXACT []
is_a: elmo:3620033 ! mechanical hydrological alteration process
