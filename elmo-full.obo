[Term]
id: PATO:0000001
name: quality
def: "A dependent entity that inheres in a bearer by virtue of how the bearer is related to other entities" [PATOC:GVG]
is_a: BFO:0000020 ! specifically dependent continuant

[Term]
id: elmo:3620020
name: mechanical ecosystem management process
def: "An active ecosystem management process during which a human employs machines or tools to directly impact an ecosystem and realize some ecosystem management goal." []
is_a: ENVO:01001170 ! active ecosystem management process
property_value: dcterms:contributor https://orcid.org/0000-0002-4366-3088
property_value: dcterms:contributor https://orcid.org/0000-0003-4817-0423
property_value: ELMOP:hasCASCode "2" xsd:string
property_value: skos:broadMatch https://w3id.org/elmo/cas/2
created_by: https://orcid.org/0000-0002-1296-2528

[Term]
id: elmo:3620021
name: mechanical vegetation removal process
def: "A mechanical ecosystem management process during which vegetation is removed." []
is_a: elmo:3620020 ! mechanical ecosystem management process
property_value: dcterms:contributor https://orcid.org/0000-0002-4366-3088
property_value: dcterms:contributor https://orcid.org/0000-0003-4817-0423
property_value: ELMOP:hasCASCode "2.2" xsd:string
property_value: ELMOP:hasCASCode "2.3" xsd:string
property_value: skos:broadMatch https://w3id.org/elmo/cas/2.2
property_value: skos:broadMatch https://w3id.org/elmo/cas/2.3
created_by: https://orcid.org/0000-0002-1296-2528

[Term]
id: elmo:3620022
name: grubbing process
def: "A mechanical vegetation removal process in which vegetation is uprooted by severing subsoil roots and prying or pulling the plant from the ground, using hand tools such as a spade, mattock, or root wrench." []
synonym: "root wrench removal" RELATED []
synonym: "spading removal" RELATED []
synonym: "uprooting" RELATED []
is_a: elmo:3620021 ! mechanical vegetation removal process
property_value: dcterms:contributor https://orcid.org/0000-0002-4366-3088
property_value: dcterms:contributor https://orcid.org/0000-0003-4817-0423
property_value: ELMOP:hasCASCode "2.3" xsd:string
property_value: skos:broadMatch https://w3id.org/elmo/cas/2.3
created_by: https://orcid.org/0000-0002-1296-2528

[Term]
id: elmo:3620023
name: cut and cover removal process
def: "A mechanical vegetation removal process during which plants at ground level are cut and residual stumps are covered with a sun-blocking material (e.g. silage tarp)." []
synonym: "solarization" RELATED []
is_a: elmo:3620021 ! mechanical vegetation removal process
property_value: dcterms:contributor https://orcid.org/0000-0002-4366-3088
property_value: dcterms:contributor https://orcid.org/0000-0003-4817-0423
property_value: ELMOP:hasCASCode "2.3" xsd:string
property_value: skos:broadMatch https://w3id.org/elmo/cas/2.3
created_by: https://orcid.org/0000-0002-1296-2528

[Term]
id: elmo:3620024
name: cutting removal process
def: "A mechanical vegetation removal process in which a human cuts plant material above ground level. Cut material may be removed from the site (e.g. logging) or left in place (e.g. mowing). Methods include chainsaws, brushcutters, mowers, and hand tools." []
is_a: elmo:3620021 ! mechanical vegetation removal process
property_value: dcterms:contributor https://orcid.org/0000-0002-4366-3088
property_value: dcterms:contributor https://orcid.org/0000-0003-4817-0423
property_value: ELMOP:hasCASCode "2.3" xsd:string
property_value: skos:broadMatch https://w3id.org/elmo/cas/2.3
created_by: https://orcid.org/0000-0002-1296-2528

[Term]
id: elmo:3620025
name: spading removal process
def: "A mechanical vegetation removal process in which a human severs subsoil roots using a spade and pries the plant out of the ground." [https://www.ontarioinvasiveplants.ca/wp-content/uploads/2018/05/OPWG-Spading-Postcard-1.pdf]
is_a: elmo:3620021 ! mechanical vegetation removal process
property_value: dcterms:contributor https://orcid.org/0000-0002-4366-3088
property_value: dcterms:contributor https://orcid.org/0000-0003-4817-0423
property_value: ELMOP:hasCASCode "2.3" xsd:string
property_value: IAO:0000116 "This term has been merged into grubbing process (ELMO:3620022). See that term for the consolidated definition." xsd:string
property_value: skos:broadMatch https://w3id.org/elmo/cas/2.3
created_by: https://orcid.org/0000-0002-1296-2528

[Term]
id: elmo:3620026
name: canopy thinning process
def: "A mechanical vegetation removal process in which a human removes trees or large shrubs from a given area with goals that may include increasing light availability for understorey plants, reducing wildfire risk, or improving wildlife habitat." [doi:10.1111/rec.13043]
is_a: elmo:3620021 ! mechanical vegetation removal process
property_value: dcterms:contributor https://orcid.org/0000-0002-4366-3088
property_value: dcterms:contributor https://orcid.org/0000-0003-4817-0423
property_value: ELMOP:hasCASCode "2.3" xsd:string
property_value: skos:broadMatch https://w3id.org/elmo/cas/2.3
created_by: https://orcid.org/0000-0002-1296-2528

[Term]
id: elmo:3620027
name: leaf litter removal process
def: "A mechanical ecosystem management process in which a human removes accumulated leaf litter from the ground surface, typically to reduce the seedbank of invasive plants, expose bare mineral soil for seeding, or alter conditions at the soil surface." []
is_a: elmo:3620020 ! mechanical ecosystem management process
property_value: dcterms:contributor https://orcid.org/0000-0002-4366-3088
property_value: dcterms:contributor https://orcid.org/0000-0003-4817-0423
