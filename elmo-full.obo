[Term]
id: elmo:3620502
name: fertilizer application process
def: "A chemical application process in which a human applies fertilizer or nutrient amendments to a given area with the goal of increasing soil fertility or plant growth. Fertilizer may supply macronutrients (nitrogen, phosphorus, potassium), micronutrients, or organic matter." [wd:Q1213511]
is_a: elmo:3620501 ! chemical application process
property_value: dcterms:contributor https://orcid.org/0000-0002-4366-3088
property_value: dcterms:contributor https://orcid.org/0000-0003-4817-0423
property_value: ELMOP:hasCASCode "2.3" xsd:string
property_value: skos:broadMatch https://w3id.org/elmo/cas/2.3
created_by: https://orcid.org/0000-0002-1296-2528

[Term]
id: elmo:3620503
name: lime application process
def: "A chemical application process in which a human adds lime to soil or water in order to raise the pH and reduce acidity, thereby improving conditions for plant growth or reducing the availability of toxic compounds." [doi:10.1046/j.1365-2427.2001.00788.x]
is_a: elmo:3620501 ! chemical application process
property_value: dcterms:contributor https://orcid.org/0000-0002-4366-3088
property_value: dcterms:contributor https://orcid.org/0000-0003-4817-0423
property_value: ELMOP:hasCASCode "2.3" xsd:string
property_value: IAO:0000116 "Corrected: the previous definition incorrectly stated that lime reduces pH. Lime raises pH, making soil less acidic." xsd:string
property_value: skos:broadMatch https://w3id.org/elmo/cas/2.3
created_by: https://orcid.org/0000-0002-1296-2528

[Term]
id: elmo:3620504
name: herbicide application process
def: "A chemical application process in which a human applies herbicide to plants or soil in a given area." [doi:10.1111/avsc.12183]
is_a: elmo:3620501 ! chemical application process
property_value: dcterms:contributor https://orcid.org/0000-0002-4366-3088
