        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A subbiome of the Temperate-Boreal Grassland and Shrubland biome comprising continental boreal shrublands and grasslands at high latitudes characterised by cold continental climates, short growing seasons, and low productivity.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298950/Continental_Boreal_Shrubland_Grassland_Subbiome"/>
