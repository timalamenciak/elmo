    <!-- http://purl.obolibrary.org/obo/ENVO_01001170 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ENVO_01001170">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ENVO_02500000"/>
