    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620617"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A seed treatment process in which a human damages the coating of the seed, usually using sandpaper, to enhance germination.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.1111/rec.13210"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620618 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620618">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620616"/>
        <obo:IAO_0000115 xml:lang="en">A seed treatment process in which a human applies heat to some seed in order to enhance germination.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
