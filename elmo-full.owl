        <rdfs:label xml:lang="en">supplemental water process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/3.2"/>
        <ELMOP:hasCASCode>3.2</ELMOP:hasCASCode>
    </owl:Class>
    


