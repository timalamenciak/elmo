    <!-- https://w3id.org/elmo/elmo_3620610 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620610">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620609"/>
        <obo:IAO_0000115 xml:lang="en">A seeding process in which a human sows tree seeds.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">This term is deprecated. Tree seeds are sown using the same techniques as other seeds. Use seeding process (ELMO:3620609) or an appropriate sub-term instead.</obo:IAO_0000116>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
