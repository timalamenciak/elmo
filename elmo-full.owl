    </owl:Class>
    


    <!-- https://w3id.org/elmo/elmo_3620631 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620631">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620630"/>
        <obo:IAO_0000115 xml:lang="en">A plant material transfer process in which a human collects material from the moss layer (approximately the top 10 cm) of a donor peatland and transfers it to a restoration site to reintroduce peatland-forming mosses and associated species.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Hydrological restoration steps (e.g. blocking drainage ditches) that may precede or accompany moss transfer should be represented as separate processes under mechanical hydrological alteration process.</obo:IAO_0000116>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">moss layer transfer process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620631"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A plant material transfer process in which a human collects material from the moss layer (approximately the top 10 cm) of a donor peatland and transfers it to a restoration site to reintroduce peatland-forming mosses and associated species.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.1016/j.ecoleng.2014.03.051"/>
    </owl:Axiom>
    


