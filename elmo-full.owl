        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620213"/>
        <obo:IAO_0000115 xml:lang="en">A subbiome of the Intensive land-use biome comprising cultivated croplands, pastures, and managed farmlands characterised by human modification of the land surface for food, fibre, and biomass production.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
