    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620054 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620054">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620043"/>
        <obo:IAO_0000115 xml:lang="en">An earthworks process in which a human installs material, which may be inorganic (e.g. rock riprap, geotextile mesh) or organic (e.g. timber cribbing, live stakes), to stabilize the bank of a body of water and reduce erosion.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">shoreline reinforcement process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620054"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">An earthworks process in which a human installs material, which may be inorganic (e.g. rock riprap, geotextile mesh) or organic (e.g. timber cribbing, live stakes), to stabilize the bank of a body of water and reduce erosion.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://en.wikipedia.org/wiki/Cellular_confinement"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620055 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620055">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620043"/>
        <obo:IAO_0000115 xml:lang="en">An earthworks process in which a human digs pits and creates mounds to reproduce a natural disturbance regime.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
