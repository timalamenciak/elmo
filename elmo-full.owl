    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620617 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620617">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620616"/>
        <obo:IAO_0000115 xml:lang="en">A seed treatment process in which a human damages the coating of the seed, usually using sandpaper, to enhance germination.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
