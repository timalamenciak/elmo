    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620619 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620619">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620616"/>
        <obo:IAO_0000115 xml:lang="en">A seed treatment process in which a human applies cold to some seed in order to enhance germination, such as in cold stratification.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">chill seed treatment process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
