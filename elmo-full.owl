    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620249"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A subbiome of the Temperate-Boreal Grassland and Shrubland biome comprising temperate grasslands and shrublands characterised by a dominant grass and forb layer with limited woody cover and seasonal moisture deficits.</owl:annotatedTarget>
