    <!-- https://w3id.org/elmo/elmo_3620625 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620625">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620624"/>
        <obo:IAO_0000115 xml:lang="en">A captive breeding and release process in which a human collects eggs and relocates them to a safe environment, whereupon they are allowed to hatch.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
