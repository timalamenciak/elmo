    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620256"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A subbiome of the Polar/alpine (cryogenic) biome comprising high-altitude tropical alpine ecosystems characterised by intense UV radiation, large diurnal temperature variation, and distinctive Afroalpine or Andean vegetation forms.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298956/Tropical_Alpine_Subbiome"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620257 -->

