        <rdfs:label xml:lang="en">chemical application process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.2"/>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.2</ELMOP:hasCASCode>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620501"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A chemical ecosystem management process in which a human applies some chemical to an ecosystem.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.1016/j.scitotenv.2021.148631"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620502 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620502">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620501"/>
        <obo:IAO_0000115 xml:lang="en">A chemical application process in which a human applies fertilizer or nutrient amendments to a given area with the goal of increasing soil fertility or plant growth. Fertilizer may supply macronutrients (nitrogen, phosphorus, potassium), micronutrients, or organic matter.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">fertilizer application process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620502"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A chemical application process in which a human applies fertilizer or nutrient amendments to a given area with the goal of increasing soil fertility or plant growth. Fertilizer may supply macronutrients (nitrogen, phosphorus, potassium), micronutrients, or organic matter.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="wd:Q1213511"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620503 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620503">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620501"/>
        <obo:IAO_0000115 xml:lang="en">A chemical application process in which a human adds lime to soil or water in order to raise the pH and reduce acidity, thereby improving conditions for plant growth or reducing the availability of toxic compounds.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Corrected: the previous definition incorrectly stated that lime reduces pH. Lime raises pH, making soil less acidic.</obo:IAO_0000116>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">lime application process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620503"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A chemical application process in which a human adds lime to soil or water in order to raise the pH and reduce acidity, thereby improving conditions for plant growth or reducing the availability of toxic compounds.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.1046/j.1365-2427.2001.00788.x"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620504 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620504">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620501"/>
        <obo:IAO_0000115 xml:lang="en">A chemical application process in which a human applies herbicide to plants or soil in a given area.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">herbicide application process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.2"/>
        <ELMOP:hasCASCode>2.2</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620504"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A chemical application process in which a human applies herbicide to plants or soil in a given area.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.1111/avsc.12183"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620505 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620505">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620501"/>
        <obo:IAO_0000115 xml:lang="en">A herbicide application process in which a human applies the herbicide glyphosate to plants in some area.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">This term is deprecated. Glyphosate application is subsumed under herbicide application process (ELMO:3620504). Treating a single herbicide as a separate class-level term is inconsistent with the treatment of other herbicides.</obo:IAO_0000116>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">glyphosate application process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.2"/>
        <ELMOP:hasCASCode>2.2</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620505"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A herbicide application process in which a human applies the herbicide glyphosate to plants in some area.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.1111/avsc.12183"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620506 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620506">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620501"/>
        <obo:IAO_0000115 xml:lang="en">A chemical application process in which a human introduces an insecticide to some area with the goal of managing an insect population.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">insecticide application process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.2"/>
        <ELMOP:hasCASCode>2.2</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620506"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A chemical application process in which a human introduces an insecticide to some area with the goal of managing an insect population.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.1016/j.biocontrol.2018.07.012"/>
    </owl:Axiom>
    


