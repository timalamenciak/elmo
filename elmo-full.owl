    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620268"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A subbiome of the Anthropogenic shorelines biome comprising developed and modified marine shoreline ecosystems characterised by human infrastructure such as seawalls, breakwaters, and hardened coastlines.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298969/Developed_Marine_Shoreline_Subbiome"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620269 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620269">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620241"/>
        <obo:IAO_0000115 xml:lang="en">A tropical dry forest ecosystem characterised by thorny, drought-adapted trees and shrubs with sparse to moderate canopy cover, occurring in semi-arid tropical regions with a prolonged dry season.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TT1.b2</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT1.b2 Tropical Thorn Woodland</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Tropical Thorn Woodland</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620269"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A tropical dry forest ecosystem characterised by thorny, drought-adapted trees and shrubs with sparse to moderate canopy cover, occurring in semi-arid tropical regions with a prolonged dry season.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298975/Tropical_Thorn_Woodland_Ecobiome"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620270 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620270">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620243"/>
        <obo:IAO_0000115 xml:lang="en">A cool temperate forest and woodland ecosystem characterised by coniferous tree dominance in continental climates, with cold winters, moderate growing-season productivity, and often a sparse or ericaceous understorey.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TT2.b3</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT2.b3 Temperate Continental Conifer Forest &amp; Woodland</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Temperate Continental Conifer Forest &amp; Woodland</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620270"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A cool temperate forest and woodland ecosystem characterised by coniferous tree dominance in continental climates, with cold winters, moderate growing-season productivity, and often a sparse or ericaceous understorey.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298982/Temperate_Continental_Conifer_Forest_Woodland_Ecobiome"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620271 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620271">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620244"/>
        <obo:IAO_0000115 xml:lang="en">A boreal forest and woodland ecosystem characterised by coniferous tree dominance, a moss- and lichen-dominated understorey, seasonally frozen soils, and a short growing season at high latitudes.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TT2.c1</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT2.c1 Boreal Forest &amp; Woodland</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Boreal Forest &amp; Woodland</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620271"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A boreal forest and woodland ecosystem characterised by coniferous tree dominance, a moss- and lichen-dominated understorey, seasonally frozen soils, and a short growing season at high latitudes.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298976/Boreal_Forest_Woodland_Ecobiome"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620272 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620272">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620245"/>
        <obo:IAO_0000115 xml:lang="en">A tropical savanna ecosystem characterised by a continuous grass layer interspersed with scattered trees or shrubs in lowland tropical regions, maintained by seasonal drought, fire, and herbivory.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TT3.a1</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT3.a1 Tropical Lowland Savanna</oboInOwl:hasExactSynonym>
        <oboInOwl:hasNarrowSynonym xml:lang="en">ELMO:3620114</oboInOwl:hasNarrowSynonym>
        <oboInOwl:hasNarrowSynonym xml:lang="en">ELMO:3620115</oboInOwl:hasNarrowSynonym>
        <oboInOwl:hasNarrowSynonym xml:lang="en">ELMO:3620116</oboInOwl:hasNarrowSynonym>
        <rdfs:label xml:lang="en">Tropical Lowland Savanna</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620272"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A tropical savanna ecosystem characterised by a continuous grass layer interspersed with scattered trees or shrubs in lowland tropical regions, maintained by seasonal drought, fire, and herbivory.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298983/Tropical_Lowland_Savanna_Ecobiome"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620273 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620273">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620247"/>
        <obo:IAO_0000115 xml:lang="en">A tropical open-rock ecosystem characterised by exposed cliff and rock outcrop substrates, minimal soil, extreme microclimate variability, and highly specialised stress-tolerant plant communities with high local endemism.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasBroadSynonym xml:lang="en">ELMO:3620113</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT3.c1</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT3.c1 Tropical Cliff &amp; Rock Outcrop</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Tropical Cliff &amp; Rock Outcrop</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620273"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A tropical open-rock ecosystem characterised by exposed cliff and rock outcrop substrates, minimal soil, extreme microclimate variability, and highly specialised stress-tolerant plant communities with high local endemism.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298985/Tropical_Cliff_Rock_Outcrop_Ecobiome"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620274 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620274">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620250"/>
        <obo:IAO_0000115 xml:lang="en">A continental boreal ecosystem characterised by dwarf shrub or grass-dominated vegetation in cold, continental climates, typically occupying areas beyond or above the boreal forest tree line with a short growing season.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TT4.c1</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT4.c1 Boreal Shrubland &amp; Grassland</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Boreal Shrubland &amp; Grassland</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620274"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A continental boreal ecosystem characterised by dwarf shrub or grass-dominated vegetation in cold, continental climates, typically occupying areas beyond or above the boreal forest tree line with a short growing season.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298989/Boreal_Shrubland_Grassland_Ecobiome"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620275 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620275">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620251"/>
        <obo:IAO_0000115 xml:lang="en">A temperate to boreal open-rock ecosystem characterised by exposed cliff faces and rock outcrops supporting stress-tolerant vascular plants, lichens, and bryophytes adapted to shallow soils and temperature extremes.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasBroadSynonym xml:lang="en">ELMO:3620113</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT4.d1</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT4.d1 Temperate-Boreal Cliff &amp; Rock Outcrop</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Temperate-Boreal Cliff &amp; Rock Outcrop</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620275"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A temperate to boreal open-rock ecosystem characterised by exposed cliff faces and rock outcrops supporting stress-tolerant vascular plants, lichens, and bryophytes adapted to shallow soils and temperature extremes.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298990/Temperate-Boreal_Cliff_Rock_Outcrop_Ecobiome"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620276 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620276">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620252"/>
        <obo:IAO_0000115 xml:lang="en">A cool desert and semi-desert ecosystem characterised by a sparse cover of cold-tolerant shrubs and grasses on arid substrates, with low and variable precipitation, cold winters, and biological soil crusts.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TT5.a1</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT5.a1 Cool Desert &amp; Semi-desert Shrub-Steppe</oboInOwl:hasExactSynonym>
        <oboInOwl:hasNarrowSynonym xml:lang="en">ELMO:3620119</oboInOwl:hasNarrowSynonym>
        <oboInOwl:hasNarrowSynonym xml:lang="en">ELMO:3620122</oboInOwl:hasNarrowSynonym>
        <rdfs:label xml:lang="en">Cool Desert &amp; Semi-desert Shrub-Steppe</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620276"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A cool desert and semi-desert ecosystem characterised by a sparse cover of cold-tolerant shrubs and grasses on arid substrates, with low and variable precipitation, cold winters, and biological soil crusts.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298991/Cool_Desert_Semi-desert_Shrub-Steppe_Ecobiome"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620277 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620277">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620255"/>
        <obo:IAO_0000115 xml:lang="en">A polar to alpine tundra and desert ecosystem characterised by permafrost, low temperatures, a brief growing season, and low-growing vegetation dominated by grasses, sedges, mosses, lichens, and dwarf shrubs.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <rdfs:label xml:lang="en">Polar Tundra &amp; Desert</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620277"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A polar to alpine tundra and desert ecosystem characterised by permafrost, low temperatures, a brief growing season, and low-growing vegetation dominated by grasses, sedges, mosses, lichens, and dwarf shrubs.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298996/Polar_Tundra_Desert_Ecobiome"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620278 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620278">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620255"/>
        <obo:IAO_0000115 xml:lang="en">A temperate alpine ecosystem characterised by open grasslands and shrublands above the treeline, with short growing seasons, intense UV radiation, freeze-thaw cycles, and wind-adapted low-growing vegetation.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TT6.b2</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TT6.b2 Temperate Alpine Grassland &amp; Shrubland</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Temperate Alpine Grassland &amp; Shrubland</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620278"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A temperate alpine ecosystem characterised by open grasslands and shrublands above the treeline, with short growing seasons, intense UV radiation, freeze-thaw cycles, and wind-adapted low-growing vegetation.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1298997/Temperate_Alpine_Grassland_Shrubland_Ecobiome"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620279 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620279">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620261"/>
        <obo:IAO_0000115 xml:lang="en">An emergent open wetland ecosystem characterised by seasonally to permanently waterlogged soils supporting a continuous cover of herbaceous marsh plants, wet meadow grasses and sedges, or low wetland shrubs.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TP1.b1</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TP1.b1 Marsh, Wet Meadow &amp; Shrub Wetland</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Marsh, Wet Meadow &amp; Shrub Wetland</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620279"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">An emergent open wetland ecosystem characterised by seasonally to permanently waterlogged soils supporting a continuous cover of herbaceous marsh plants, wet meadow grasses and sedges, or low wetland shrubs.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1299006/Marsh_Wet_Meadow_Shrub_Wetland_Ecobiome"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620280 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620280">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620261"/>
        <obo:IAO_0000115 xml:lang="en">An emergent open wetland ecosystem characterised by irregular and episodic flooding of arid or semi-arid lowlands, supporting ephemeral wetland communities that respond rapidly to infrequent flooding events.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <rdfs:label xml:lang="en">Episodic Arid floodplain</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620280"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">An emergent open wetland ecosystem characterised by irregular and episodic flooding of arid or semi-arid lowlands, supporting ephemeral wetland communities that respond rapidly to infrequent flooding events.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1299007/Episodic_Arid_Floodplain_Ecobiome"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620281 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620281">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620261"/>
        <obo:IAO_0000115 xml:lang="en">An emergent open wetland ecosystem characterised by saline or brackish soils in inland settings, dominated by halophytic herbaceous vegetation adapted to osmotic stress and periodic inundation.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <rdfs:label xml:lang="en">Inland Salt Marsh</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620281"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">An emergent open wetland ecosystem characterised by saline or brackish soils in inland settings, dominated by halophytic herbaceous vegetation adapted to osmotic stress and periodic inundation.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1299008/Inland_Salt_Marsh_Ecobiome"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620282 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620282">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620238"/>
        <obo:IAO_0000115 xml:lang="en">A freshwater coastal ecosystem characterised by dynamic shoreline substrates of sand, gravel, or organic material along lake or river margins, supporting sparse to dense shoreline and dune vegetation.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <rdfs:label xml:lang="en">Coastal Freshwater Shore &amp; Dune</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620282"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A freshwater coastal ecosystem characterised by dynamic shoreline substrates of sand, gravel, or organic material along lake or river margins, supporting sparse to dense shoreline and dune vegetation.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://explorer.natureserve.org/Taxon/ELEMENT_GLOBAL.2.1299012/Coastal_Freshwater_Shore_Dune_Ecobiome"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620283 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620283">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620264"/>
        <obo:IAO_0000115 xml:lang="en">A developed freshwater coast ecosystem characterised by artificially modified shorelines of lakes, reservoirs, or rivers, including riprap, seawalls, and other engineered structures that alter natural shoreline processes.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">No link on NatureServe Explorer.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TP3.a1</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">TP3.a1 Developed Freshwater Shoreline</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Developed Freshwater Shoreline</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620283"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A developed freshwater coast ecosystem characterised by artificially modified shorelines of lakes, reservoirs, or rivers, including riprap, seawalls, and other engineered structures that alter natural shoreline processes.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://global-ecosystems.org/explore/groups/TF1"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620500 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620500">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ENVO_01001170"/>
        <obo:IAO_0000115 xml:lang="en">An active ecosystem management process in which a human applys or releases a chemical substance to realize some ecological management goal.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">chemical ecosystem management process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.2"/>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.2</ELMOP:hasCASCode>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620500"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">An active ecosystem management process in which a human applys or releases a chemical substance to realize some ecological management goal.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.1016/j.scitotenv.2021.148631"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620501 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620501">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620500"/>
        <obo:IAO_0000115 xml:lang="en">A chemical ecosystem management process in which a human applies some chemical to an ecosystem.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
