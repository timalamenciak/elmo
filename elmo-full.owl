        <obo:IAO_0000115 xml:lang="en">A subbiome of the Anthropogenic shorelines biome comprising developed and modified marine shoreline ecosystems characterised by human infrastructure such as seawalls, breakwaters, and hardened coastlines.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">MS3.a</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">MS3.a Developed Marine Shoreline Subbiome</oboInOwl:hasExactSynonym>
