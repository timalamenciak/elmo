        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620600"/>
        <obo:IAO_0000115 xml:lang="en">A biological ecosystem management process in which a human facilitates the breeding of fauna, rears the young for a period of time and releases them in some environment.</obo:IAO_0000115>
