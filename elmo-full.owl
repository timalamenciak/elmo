        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">An earthworks process in which a human creates a specific slope.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://en.wikipedia.org/wiki/Grading_(earthworks)"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620053 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620053">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620043"/>
        <obo:IAO_0000115 xml:lang="en">An earthworks process in which a human installs inorganic material, usually a mesh, to stabilize a slope.</obo:IAO_0000115>
