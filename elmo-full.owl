    <!-- https://w3id.org/elmo/elmo_3620611 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620611">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620609"/>
        <obo:IAO_0000115 xml:lang="en">A seeding process in which a human sows seeds in lines along a landscape.</obo:IAO_0000115>
