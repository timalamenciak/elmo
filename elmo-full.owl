        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620624"/>
        <obo:IAO_0000115 xml:lang="en">A captive breeding and release process in which a human captures young fauna, rears them into adulthood and releases them into some environment.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
