        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620255"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A subbiome of the Polar/alpine (cryogenic) biome comprising temperate to polar alpine and tundra ecosystems characterised by cold temperatures, short growing seasons, permafrost or freeze-thaw cycles, and low-growing vegetation.</owl:annotatedTarget>
