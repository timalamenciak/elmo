        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620237"/>
        <obo:IAO_0000115 xml:lang="en">A subbiome of the Temperate-Boreal Grassland and Shrubland biome comprising temperate grasslands and shrublands characterised by a dominant grass and forb layer with limited woody cover and seasonal moisture deficits.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Definition sourced from IUCN Global Ecosystem Typology (https://global-ecosystems.org) and adapted for ontology use.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym xml:lang="en">TT4.b</oboInOwl:hasExactSynonym>
