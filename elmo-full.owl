    <!-- https://w3id.org/elmo/elmo_3620020 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620020">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ENVO_01001170"/>
        <obo:IAO_0000115 xml:lang="en">An active ecosystem management process during which a human employs machines or tools to directly impact an ecosystem and realize some ecosystem management goal.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">mechanical ecosystem management process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2"/>
        <ELMOP:hasCASCode>2</ELMOP:hasCASCode>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/elmo_3620021 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620021">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620020"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical ecosystem management process during which vegetation is removed.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">mechanical vegetation removal process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.2"/>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.2</ELMOP:hasCASCode>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/elmo_3620022 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620022">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620021"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical vegetation removal process in which vegetation is uprooted by severing subsoil roots and prying or pulling the plant from the ground, using hand tools such as a spade, mattock, or root wrench.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <oboInOwl:hasRelatedSynonym xml:lang="en">root wrench removal</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym xml:lang="en">spading removal</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym xml:lang="en">uprooting</oboInOwl:hasRelatedSynonym>
        <rdfs:label xml:lang="en">grubbing process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/elmo_3620023 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620023">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620021"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical vegetation removal process during which plants at ground level are cut and residual stumps are covered with a sun-blocking material (e.g. silage tarp).</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <oboInOwl:hasRelatedSynonym xml:lang="en">solarization</oboInOwl:hasRelatedSynonym>
        <rdfs:label xml:lang="en">cut and cover removal process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/elmo_3620024 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620024">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620021"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical vegetation removal process in which a human cuts plant material above ground level. Cut material may be removed from the site (e.g. logging) or left in place (e.g. mowing). Methods include chainsaws, brushcutters, mowers, and hand tools.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">cutting removal process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/elmo_3620025 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620025">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620021"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical vegetation removal process in which a human severs subsoil roots using a spade and pries the plant out of the ground.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">This term has been merged into grubbing process (ELMO:3620022). See that term for the consolidated definition.</obo:IAO_0000116>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">spading removal process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620025"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A mechanical vegetation removal process in which a human severs subsoil roots using a spade and pries the plant out of the ground.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://www.ontarioinvasiveplants.ca/wp-content/uploads/2018/05/OPWG-Spading-Postcard-1.pdf"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620026 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620026">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620021"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical vegetation removal process in which a human removes trees or large shrubs from a given area with goals that may include increasing light availability for understorey plants, reducing wildfire risk, or improving wildlife habitat.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">canopy thinning process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620026"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A mechanical vegetation removal process in which a human removes trees or large shrubs from a given area with goals that may include increasing light availability for understorey plants, reducing wildfire risk, or improving wildlife habitat.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.1111/rec.13043"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620027 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620027">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620020"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical ecosystem management process in which a human removes accumulated leaf litter from the ground surface, typically to reduce the seedbank of invasive plants, expose bare mineral soil for seeding, or alter conditions at the soil surface.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">leaf litter removal process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/elmo_3620028 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620028">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620020"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical ecosystem management process in which a human controls fauna populations.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">mechanical fauna control process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.2"/>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/3.1"/>
        <ELMOP:hasCASCode>2.2</ELMOP:hasCASCode>
        <ELMOP:hasCASCode>3.1</ELMOP:hasCASCode>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/elmo_3620029 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620029">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620028"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical fauna control process in which a human uses traps to control fauna.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">mammal trapping process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/3.1"/>
        <ELMOP:hasCASCode>3.1</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620029"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A mechanical fauna control process in which a human uses traps to control fauna.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://en.wikipedia.org/wiki/Trapping"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620030 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620030">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620028"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical fauna control process in which a human targets predators for removal from the ecosystem.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">predator control process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.2"/>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/3.1"/>
        <ELMOP:hasCASCode>2.2</ELMOP:hasCASCode>
        <ELMOP:hasCASCode>3.1</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620030"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A mechanical fauna control process in which a human targets predators for removal from the ecosystem.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://agrilife.org/txwildlifeservices/files/2011/07/PredatorControlforWildlifeMgt.pdf"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620031 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620031">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620067"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical fauna control process in which a human installs fencing to restrict either immigration or emmigration of fauna from a particular area.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">fencing process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/1.2"/>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.2"/>
        <ELMOP:hasCASCode>1.2</ELMOP:hasCASCode>
        <ELMOP:hasCASCode>2.2</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620031"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A mechanical fauna control process in which a human installs fencing to restrict either immigration or emmigration of fauna from a particular area.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.1016/j.biocon.2017.08.001"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620032 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620032">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620028"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical fauna control process in which a human installs an electronic device to deter species from a particular area.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">mechanical species deterrent process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.2"/>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/3.1"/>
        <ELMOP:hasCASCode>2.2</ELMOP:hasCASCode>
        <ELMOP:hasCASCode>3.1</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620032"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A mechanical fauna control process in which a human installs an electronic device to deter species from a particular area.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.1111/jfb.13769"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620033 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620033">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620020"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical ecosystem management process during which a human deliberately alters the hydrologic cycle in an area.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">mechanical hydrological alteration process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620033"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A mechanical ecosystem management process during which a human deliberately alters the hydrologic cycle in an area.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://en.wikipedia.org/wiki/Water_cycle"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620034 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620034">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620033"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical hydrological alteration process in which a human constructs a dam or barrier across a watercourse for ecological restoration purposes, such as to restore a meander sequence or to raise the water table of adjacent wetlands.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <oboInOwl:hasExactSynonym xml:lang="en">beaver dam analogue</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">dam construction process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.1"/>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.1</ELMOP:hasCASCode>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620034"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A mechanical hydrological alteration process in which a human constructs a dam or barrier across a watercourse for ecological restoration purposes, such as to restore a meander sequence or to raise the water table of adjacent wetlands.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.1093/biosci/biu036"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620035 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620035">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620033"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical hydrological alteration process in which a human removes a dam or barrier with the goal of altering the hydroperiod of surrounding lands and reconnecting rivers to their floodplains.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">dam removal process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620035"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A mechanical hydrological alteration process in which a human removes a dam or barrier with the goal of altering the hydroperiod of surrounding lands and reconnecting rivers to their floodplains.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.12952/journal.elementa.000108"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620036 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620036">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620033"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical hydrological alteration process in which a human decommissions subterranean tile drains by collapsing them in situ or by excavating and removing them, in order to reduce drainage and restore wetland hydroperiod.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">This term consolidates the formerly separate tile drain crushing process and tile drain removal process, as both achieve the same management goal by similar means.</obo:IAO_0000116>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <oboInOwl:hasExactSynonym xml:lang="en">drain removal process</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">tile drain crushing process</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">tile drain removal process</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">tile drain decommissioning process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/elmo_3620037 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620037">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620033"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical hydrological alteration process in which a human uncovers and removes subterranean tile drains to reduce drainage on the landscape and restore wetland hydroperiod.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">This term has been merged into tile drain decommissioning process (ELMO:3620036). See that term for the consolidated definition.</obo:IAO_0000116>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">tile drain removal process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/elmo_3620038 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620038">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620020"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical ecosystem management process in which a human creates or installs structures to provide nesting, roosting, or denning sites for fauna. Examples include bird nest boxes, raptor nesting platforms, bat boxes, and nesting mounds for turtles.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">nest site creation process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/3.2"/>
        <ELMOP:hasCASCode>3.2</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620038"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A mechanical ecosystem management process in which a human creates or installs structures to provide nesting, roosting, or denning sites for fauna. Examples include bird nest boxes, raptor nesting platforms, bat boxes, and nesting mounds for turtles.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.1186/S41610-021-00192-Z"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620039 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620039">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620020"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical ecosystem management process in which a human creates structures such as posts, platforms, or dead snags for wildlife to perch or roost on. Such structures are used by birds of prey, bats, and other arboreal fauna.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">perch and roost creation process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/3.2"/>
        <ELMOP:hasCASCode>3.2</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620039"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A mechanical ecosystem management process in which a human creates structures such as posts, platforms, or dead snags for wildlife to perch or roost on. Such structures are used by birds of prey, bats, and other arboreal fauna.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.1007/s11258-016-0619-4"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620040 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620040">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620020"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical ecosystem management process in which a human establishes strips of vegetation between landscape features such as agricultural fields and watercourses, using earthworks and planting processes.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">buffer strip creation process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/1.2"/>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>1.2</ELMOP:hasCASCode>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620040"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A mechanical ecosystem management process in which a human establishes strips of vegetation between landscape features such as agricultural fields and watercourses, using earthworks and planting processes.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.2134/jeq2018.03.0120"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620041 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620041">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620040"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical ecosystem management process in which a human establishes strips of vegetation in the riparian areas of watercourses such as rivers, streams, and creeks.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">riparian buffer strip creation process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/1.2"/>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>1.2</ELMOP:hasCASCode>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620041"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A mechanical ecosystem management process in which a human establishes strips of vegetation in the riparian areas of watercourses such as rivers, streams, and creeks.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.1890/08-2064.1"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620042 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620042">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620020"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical ecosystem management process in which a human leaves strips of vegetation untouched when clearing land for other purposes, with the goal of retaining their ecological function as a buffer between landscape features.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Retention of an existing vegetated buffer may constitute an active management decision (e.g. legal protection or explicit exclusion from clearing). Consider whether passive retention qualifies as a mechanical process.</obo:IAO_0000116>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">buffer strip retention process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/1.2"/>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>1.2</ELMOP:hasCASCode>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620042"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A mechanical ecosystem management process in which a human leaves strips of vegetation untouched when clearing land for other purposes, with the goal of retaining their ecological function as a buffer between landscape features.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.2134/jeq2018.03.0120"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3620043 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620043">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620020"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical ecosystem management process during which the topology of some area is deliberately changed at least at the micro scale (e.g. 1m2).</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Difficult to suggest a firm border for scale. I doubt digging out a small hole would be called earthworks but settled on at least 1 m2 of earth moved. See Landscape Microscale Size and its associated scale properties for more nuance: ENVO:03620005; ENVO:03620006; ENVO:03620007; ENVO:03620008</obo:IAO_0000116>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">earthworks process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.1"/>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.1</ELMOP:hasCASCode>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/elmo_3620044 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3620044">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620043"/>
        <obo:IAO_0000115 xml:lang="en">An earthworks process in which earthen barriers (berms) are constructed with the goal of obstructing or slowing floodwaters.</obo:IAO_0000115>
