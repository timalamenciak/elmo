        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620212"/>
        <obo:IAO_0000115 xml:lang="en">A subbiome of the Polar/alpine (cryogenic) biome comprising temperate to polar alpine and tundra ecosystems characterised by cold temperatures, short growing seasons, permafrost or freeze-thaw cycles, and low-growing vegetation.</obo:IAO_0000115>
