        <oboInOwl:hasExactSynonym xml:lang="en">TT5.a Cool Semi-desert Subbiome</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Cool Semi-desert Subbiome</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3620252"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A subbiome of the Deserts and semi-deserts biome comprising cool arid and semi-arid ecosystems characterised by low and variable precipitation, cold winters, and sparse shrub-steppe or herbaceous vegetation.</owl:annotatedTarget>
