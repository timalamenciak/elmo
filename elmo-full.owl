    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3621017">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3621016"/>
        <obo:IAO_0000115 xml:lang="en">A forestry process in which a human cuts trees down to the stump, allowing the trees to regenerate from the stump.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">coppice process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.1"/>
        <ELMOP:hasCASCode>2.1</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3621017"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A forestry process in which a human cuts trees down to the stump, allowing the trees to regenerate from the stump.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://en.wikipedia.org/wiki/Coppicing"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3621018 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3621018">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3621016"/>
        <obo:IAO_0000115 xml:lang="en">A forestry process in which a human harvests trees according to their age with the goal of preserving some overall age for a forest stand.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">selective harvesting process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.1"/>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/6.1"/>
        <ELMOP:hasCASCode>2.1</ELMOP:hasCASCode>
        <ELMOP:hasCASCode>6.1</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3621018"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A forestry process in which a human harvests trees according to their age with the goal of preserving some overall age for a forest stand.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://en.wikipedia.org/wiki/Selection_cutting"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3621019 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3621019">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3621016"/>
        <obo:IAO_0000115 xml:lang="en">A forestry process in which a human removes coarse woody debris after harvesting trees, thereby reducing the risk and intensity of forest fire.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">woody debris removal process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3621019"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A forestry process in which a human removes coarse woody debris after harvesting trees, thereby reducing the risk and intensity of forest fire.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://en.wikipedia.org/wiki/Coarse_woody_debris"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3621020 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3621020">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3621016"/>
        <obo:IAO_0000115 xml:lang="en">A forestry process in which a human leaves coarse woody debris after harvesting, thereby increasing available resources.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">leave woody debris</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3621020"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A forestry process in which a human leaves coarse woody debris after harvesting, thereby increasing available resources.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://en.wikipedia.org/wiki/Coarse_woody_debris"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3621021 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3621021">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3621016"/>
        <obo:IAO_0000115 xml:lang="en">A forestry process in which a human primarily harvests large trees in order to increase light availability for seedling species.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">shelterwood cutting process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.1"/>
        <ELMOP:hasCASCode>2.1</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3621021"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A forestry process in which a human primarily harvests large trees in order to increase light availability for seedling species.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://en.wikipedia.org/wiki/Shelterwood_cutting"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3621022 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3621022">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ENVO_01001436"/>
        <obo:IAO_0000115 xml:lang="en">A planned environmental usage process in which a human modifies the level of wind speed required to spin turbines, thereby preventing avifauna fatalities.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <oboInOwl:hasBroadSynonym xml:lang="en">doi:10.1002/2688-8319.12371</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">curtailment</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">regulate wind turbine speed</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.1"/>
        <ELMOP:hasCASCode>2.1</ELMOP:hasCASCode>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/elmo/elmo_3621022"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A planned environmental usage process in which a human modifies the level of wind speed required to spin turbines, thereby preventing avifauna fatalities.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="doi:10.1002/2688-8319.12371"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/elmo/elmo_3621023 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3621023">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620500"/>
        <obo:IAO_0000115 xml:lang="en">A chemical ecosystem management process in which poison is introduced to reduce the population of fauna.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4817-0423"/>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <rdfs:label xml:lang="en">fauna poisoning process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/3.1"/>
        <ELMOP:hasCASCode>3.1</ELMOP:hasCASCode>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/elmo_3621024 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3621024">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620033"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical hydrological alteration process in which a human installs subsurface tile drains to manage soil water levels, typically to reduce drainage from waterlogged soils or to control water levels on a restoration site.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Added following Delphi survey recommendations.</obo:IAO_0000116>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-03-18T00:00:00Z</oboInOwl:creation_date>
        <rdfs:label xml:lang="en">tile drain installation process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/elmo_3621025 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3621025">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620033"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical hydrological alteration process in which a human installs a water control structure such as a weir, sluice gate, or stop-log to regulate water levels in a wetland, stream, or drainage ditch for ecological restoration purposes.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Added following Delphi survey recommendations.</obo:IAO_0000116>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-03-18T00:00:00Z</oboInOwl:creation_date>
        <oboInOwl:hasExactSynonym xml:lang="en">sluice installation</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">weir installation</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">water control structure installation process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/elmo_3621026 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3621026">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620501"/>
        <obo:IAO_0000115 xml:lang="en">A chemical application process in which a human applies a fungicide to a restoration site or to plant material in order to manage fungal pathogens that threaten plants or other organisms of conservation concern.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Added following Delphi survey recommendations.</obo:IAO_0000116>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-03-18T00:00:00Z</oboInOwl:creation_date>
        <rdfs:label xml:lang="en">fungicide application process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.2"/>
        <ELMOP:hasCASCode>2.2</ELMOP:hasCASCode>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/elmo_3621027 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3621027">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620501"/>
        <obo:IAO_0000115 xml:lang="en">A chemical application process in which a human applies an acidifying amendment such as elemental sulfur to soil or water in order to lower the pH and improve conditions for acid-tolerant species such as heathland or bog vegetation.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Added following Delphi survey recommendations to complement lime application process, which raises pH.</obo:IAO_0000116>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-03-18T00:00:00Z</oboInOwl:creation_date>
        <oboInOwl:hasRelatedSynonym xml:lang="en">soil pH amendment</oboInOwl:hasRelatedSynonym>
        <rdfs:label xml:lang="en">soil acidification process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/elmo_3621028 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3621028">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620609"/>
        <obo:IAO_0000115 xml:lang="en">A seeding process in which a human distributes seeds encased in a ball of clay or organic material. Seed balls protect seeds from desiccation and predation and can be dispersed by hand, slingshot, or aerial drop into areas that are difficult to access.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Added following Delphi survey recommendations.</obo:IAO_0000116>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-03-18T00:00:00Z</oboInOwl:creation_date>
        <oboInOwl:hasExactSynonym xml:lang="en">seed pellet application</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">seedbomb application</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">seed ball application process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/elmo_3621029 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3621029">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620630"/>
        <obo:IAO_0000115 xml:lang="en">A plant material transfer process in which a human cuts hay from a species-rich donor site and spreads it on a receptor restoration site in order to introduce plant propagules and associated invertebrates.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Added following Delphi survey recommendations.</obo:IAO_0000116>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-03-18T00:00:00Z</oboInOwl:creation_date>
        <oboInOwl:hasExactSynonym xml:lang="en">green hay transfer</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">hay strewing</oboInOwl:hasExactSynonym>
        <oboInOwl:hasRelatedSynonym xml:lang="en">brush harvesting</oboInOwl:hasRelatedSynonym>
        <rdfs:label xml:lang="en">hay transfer process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/elmo_3621030 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3621030">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620630"/>
        <obo:IAO_0000115 xml:lang="en">A plant material transfer process in which a human moves intact blocks of vegetation and soil from a donor site to a receptor restoration site in order to introduce plant communities and associated soil biota.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Added following Delphi survey recommendations.</obo:IAO_0000116>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-03-18T00:00:00Z</oboInOwl:creation_date>
        <oboInOwl:hasExactSynonym xml:lang="en">sod transplant process</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">turf transplant process</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">sod transfer process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/elmo_3621031 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3621031">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620630"/>
        <obo:IAO_0000115 xml:lang="en">A plant material transfer process in which a human collects leaf litter and organic material from the forest floor of a donor site and spreads it on a restoration site to introduce seeds, spores, soil invertebrates, and soil microbiota characteristic of forest ecosystems.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Added following Delphi survey recommendations.</obo:IAO_0000116>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-03-18T00:00:00Z</oboInOwl:creation_date>
        <rdfs:label xml:lang="en">forest floor litter transfer process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/elmo_3621032 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3621032">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620630"/>
        <obo:IAO_0000115 xml:lang="en">A plant material transfer process in which a human excavates and transports wetland topsoil or sediment, rich in seeds and soil microbiota, from a donor wetland to a degraded or restored wetland receptor site in order to accelerate vegetation establishment.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Added following Delphi survey recommendations.</obo:IAO_0000116>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-03-18T00:00:00Z</oboInOwl:creation_date>
        <oboInOwl:hasExactSynonym xml:lang="en">wetland muck transfer</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">wetland seedbank transfer process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/elmo_3621033 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3621033">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620600"/>
        <obo:IAO_0000115 xml:lang="en">A biological ecosystem management process in which a human introduces beneficial microorganisms such as nitrogen-fixing bacteria or mycorrhizal fungi spores to soil or plant propagules in order to improve plant establishment and soil function at a restoration site.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Added following Delphi survey recommendations. Mycorrhizae addition process (ELMO:3620645) is retained as a narrower term.</obo:IAO_0000116>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-03-18T00:00:00Z</oboInOwl:creation_date>
        <oboInOwl:hasBroadSynonym xml:lang="en">mycorrhizae addition process</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasRelatedSynonym xml:lang="en">bioinoculant application</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym xml:lang="en">rhizobial inoculation</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym xml:lang="en">soil inoculation</oboInOwl:hasRelatedSynonym>
        <rdfs:label xml:lang="en">microbial inoculation process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/elmo_3621034 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3621034">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620801"/>
        <obo:IAO_0000115 xml:lang="en">A legislation process in which a local or municipal government passes bylaws or regulations with pro-conservation goals, such as prohibiting development in sensitive habitats or requiring urban green infrastructure.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Added following Delphi survey recommendations to complement provincial/state and national legislation process terms.</obo:IAO_0000116>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-03-18T00:00:00Z</oboInOwl:creation_date>
        <oboInOwl:hasRelatedSynonym xml:lang="en">local bylaw process</oboInOwl:hasRelatedSynonym>
        <rdfs:label xml:lang="en">municipal legislation process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/5.1.3"/>
        <ELMOP:hasCASCode>5.1.3</ELMOP:hasCASCode>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/elmo_3621035 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3621035">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620021"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical vegetation removal process in which a human cuts vegetation and chips or shreds it in place, leaving the resulting mulch on the ground surface. This simultaneously removes standing vegetation and deposits organic matter on the soil.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Added following Delphi survey recommendations.</obo:IAO_0000116>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-03-18T00:00:00Z</oboInOwl:creation_date>
        <oboInOwl:hasRelatedSynonym xml:lang="en">chop and drop</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym xml:lang="en">mulch mowing</oboInOwl:hasRelatedSynonym>
        <rdfs:label xml:lang="en">cut and mulch process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/elmo_3621036 -->

    <owl:Class rdf:about="https://w3id.org/elmo/elmo_3621036">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/elmo_3620021"/>
        <obo:IAO_0000115 xml:lang="en">A mechanical vegetation removal process in which a human uses a mower to cut vegetation to a defined height above ground level. The cut material may be left in place or collected and removed. Mowing is commonly used to manage grassland, meadow, and road verge vegetation.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Added following Delphi survey recommendations.</obo:IAO_0000116>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-1296-2528"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-03-18T00:00:00Z</oboInOwl:creation_date>
        <oboInOwl:hasBroadSynonym xml:lang="en">cutting removal process</oboInOwl:hasBroadSynonym>
        <rdfs:label xml:lang="en">mowing process</rdfs:label>
        <skos:broadMatch rdf:resource="https://w3id.org/elmo/cas/2.3"/>
        <ELMOP:hasCASCode>2.3</ELMOP:hasCASCode>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/ConservationAction -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/ConservationAction">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <obo:IAO_0000115 xml:lang="en">A process undertaken by humans or organizations to protect, manage, or restore biodiversity and ecosystem services.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">conservation action</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/1 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/1">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/ConservationAction"/>
        <obo:IAO_0000115 xml:lang="en">A conservation action in which land or water areas are formally or voluntarily protected from harmful activities to conserve biodiversity.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Land/water protection</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/1.1 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/1.1">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/1"/>
        <obo:IAO_0000115 xml:lang="en">A land/water protection action in which a specific site or area is formally designated for conservation through legal or institutional mechanisms.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Site/area protection</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/1.2 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/1.2">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/1"/>
        <obo:IAO_0000115 xml:lang="en">A land/water protection action in which specific natural resources or habitats are legally or institutionally safeguarded from exploitation or degradation.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Resource &amp; habitat protection</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/2 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/2">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/ConservationAction"/>
        <obo:IAO_0000115 xml:lang="en">A conservation action in which land or water areas are actively managed to maintain or improve their biodiversity values and ecological function.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Land/water management</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/2.1 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/2.1">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/2"/>
        <obo:IAO_0000115 xml:lang="en">A land/water management action in which a specific site or area is actively managed using on-the-ground interventions to achieve defined conservation objectives.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Site/area management</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/2.2 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/2.2">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/2"/>
        <obo:IAO_0000115 xml:lang="en">A land/water management action in which invasive or otherwise problematic species are controlled, suppressed, or eradicated to reduce their negative impacts on native biodiversity.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Invasive/problematic species control</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/2.3 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/2.3">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/2"/>
        <obo:IAO_0000115 xml:lang="en">A land/water management action in which degraded habitats or disrupted natural ecological processes are actively restored toward a more natural condition.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Habitat &amp; natural process restoration</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/3 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/3">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/ConservationAction"/>
        <obo:IAO_0000115 xml:lang="en">A conservation action directed at managing, recovering, or maintaining populations of one or more species.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Species management</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/3.1 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/3.1">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/3"/>
        <obo:IAO_0000115 xml:lang="en">A species management action in which the population size, structure, or dynamics of a species are directly regulated through human intervention.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Species management</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/3.1.1 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/3.1.1">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/3.1"/>
        <obo:IAO_0000115 xml:lang="en">A species management action in which the harvest or take of a species is regulated or controlled to maintain sustainable population levels.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Harvest management</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/3.1.2 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/3.1.2">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/3.1"/>
        <obo:IAO_0000115 xml:lang="en">A species management action in which the trade in a species or its products is regulated or controlled to prevent unsustainable exploitation.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Trade management</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/3.1.3 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/3.1.3">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/3.1"/>
        <obo:IAO_0000115 xml:lang="en">A species management action in which the growth of a species population is actively limited, typically to reduce overabundance or human-wildlife conflict.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Limiting population growth</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/3.2 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/3.2">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/3"/>
        <obo:IAO_0000115 xml:lang="en">A species management action in which active interventions are carried out to increase the size or improve the conservation status of a threatened species population.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Species recovery</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/3.3 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/3.3">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/3"/>
        <obo:IAO_0000115 xml:lang="en">A species management action in which individuals of a species are deliberately moved to and released at a location where the species has been extirpated or was previously absent.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Species re-introduction</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/3.3.1 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/3.3.1">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/3.3"/>
        <obo:IAO_0000115 xml:lang="en">A species re-introduction action in which individuals are released into a site within the species&apos; historical native range where the species no longer occurs.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Reintroduction</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/3.3.2 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/3.3.2">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/3.3"/>
        <obo:IAO_0000115 xml:lang="en">A species re-introduction action in which individuals are intentionally moved and released at a location outside the species&apos; historical range to fulfil an ecological or conservation function.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Benign introduction</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/3.4 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/3.4">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/3"/>
        <obo:IAO_0000115 xml:lang="en">A species management action in which individuals, reproductive material, or genetic material are maintained outside their natural habitat for the purpose of conserving biodiversity.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Ex-situ conservation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/3.4.1 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/3.4.1">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/3.4"/>
        <obo:IAO_0000115 xml:lang="en">An ex-situ conservation action in which animals or plants are bred or propagated under controlled conditions to maintain or supplement wild populations.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Captive breeding/artificial propagation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/3.4.2 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/3.4.2">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/3.4"/>
        <obo:IAO_0000115 xml:lang="en">An ex-situ conservation action in which genetic material such as gametes, embryos, or DNA samples are collected and stored for the long-term preservation of biodiversity.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Genome resource bank</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/4 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/4">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/ConservationAction"/>
        <obo:IAO_0000115 xml:lang="en">A conservation action in which knowledge, skills, or awareness related to biodiversity and its conservation are communicated to target audiences.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Education &amp; awareness</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/4.1 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/4.1">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/4"/>
        <obo:IAO_0000115 xml:lang="en">An education and awareness action in which structured, accredited conservation knowledge and skills are delivered through schools, universities, or other formal educational institutions.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Formal education</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/4.2 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/4.2">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/4"/>
        <obo:IAO_0000115 xml:lang="en">An education and awareness action in which practical conservation skills or knowledge are provided to specific groups such as practitioners, rangers, or resource managers.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Training</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/4.3 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/4.3">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/4"/>
        <obo:IAO_0000115 xml:lang="en">An education and awareness action in which information about biodiversity threats and conservation solutions is disseminated to the general public or specific audiences through media or outreach.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Awareness &amp; communications</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/5 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/5">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/ConservationAction"/>
        <obo:IAO_0000115 xml:lang="en">A conservation action in which legal instruments, policies, or regulations are developed, strengthened, or enforced to advance biodiversity conservation.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Law &amp; policy</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/5.1 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/5.1">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/5"/>
        <obo:IAO_0000115 xml:lang="en">A law and policy action in which formal laws or statutes are developed, amended, or repealed to provide legal protection or support for biodiversity conservation.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Legislation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/5.1.1 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/5.1.1">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/5.1"/>
        <obo:IAO_0000115 xml:lang="en">A legislation action in which international treaties, conventions, or multilateral agreements are developed or ratified to protect biodiversity at the global scale.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">International level</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/5.1.2 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/5.1.2">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/5.1"/>
        <obo:IAO_0000115 xml:lang="en">A legislation action in which national laws or statutes are developed, amended, or repealed to protect biodiversity within a country&apos;s jurisdiction.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">National level</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/5.1.3 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/5.1.3">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/5.1"/>
        <obo:IAO_0000115 xml:lang="en">A legislation action in which sub-national laws or regulations such as provincial, state, or municipal statutes are developed or amended to protect biodiversity.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Sub-national level</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/5.1.4 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/5.1.4">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/5.1"/>
        <obo:IAO_0000115 xml:lang="en">A legislation action in which laws or statutes protecting biodiversity are developed or amended at a jurisdictional scale that is not specified.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Scale unspecified</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/5.2 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/5.2">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/5"/>
        <obo:IAO_0000115 xml:lang="en">A law and policy action in which non-statutory policies, administrative rules, or regulations are developed or strengthened to promote biodiversity conservation.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Policies and regulations</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/5.3 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/5.3">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/5"/>
        <obo:IAO_0000115 xml:lang="en">A law and policy action in which voluntary or mandatory standards and codes of practice are developed for the private sector to reduce its negative impacts on biodiversity.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Private sector standards &amp; codes</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/5.4 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/5.4">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/5"/>
        <obo:IAO_0000115 xml:lang="en">A law and policy action in which existing laws, regulations, or standards protecting biodiversity are enforced and adherence is actively monitored.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Compliance and enforcement</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/5.4.1 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/5.4.1">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/5.4"/>
        <obo:IAO_0000115 xml:lang="en">A compliance and enforcement action carried out through international bodies or mechanisms to ensure adherence to biodiversity-related conventions and multilateral agreements.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">International level</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/5.4.2 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/5.4.2">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/5.4"/>
        <obo:IAO_0000115 xml:lang="en">A compliance and enforcement action carried out by national authorities to ensure adherence to biodiversity-related laws and regulations within a country.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">National level</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/5.4.3 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/5.4.3">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/5.4"/>
        <obo:IAO_0000115 xml:lang="en">A compliance and enforcement action carried out by sub-national authorities such as provincial or municipal agencies to ensure adherence to biodiversity-related laws.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Sub-national level</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/5.4.4 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/5.4.4">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/5.4"/>
        <obo:IAO_0000115 xml:lang="en">A compliance and enforcement action carried out to ensure adherence to biodiversity-related laws or regulations at a jurisdictional scale that is not specified.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Scale unspecified</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/6 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/6">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/ConservationAction"/>
        <obo:IAO_0000115 xml:lang="en">A conservation action in which economic, livelihood, or social incentives are used to encourage behaviours or practices that benefit biodiversity conservation.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Livelihood, economic &amp; other incentives</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/6.1 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/6.1">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/6"/>
        <obo:IAO_0000115 xml:lang="en">A livelihood and economic incentive action in which alternative income sources or enterprises compatible with conservation goals are developed for local communities.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Linked enterprises &amp; livelihood alternatives</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/6.2 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/6.2">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/6"/>
        <obo:IAO_0000115 xml:lang="en">A livelihood and economic incentive action in which harmful or unsustainable products, practices, or exploited species are replaced with sustainable alternatives to reduce biodiversity impacts.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Substitution</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/6.3 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/6.3">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/6"/>
        <obo:IAO_0000115 xml:lang="en">A livelihood and economic incentive action in which market mechanisms such as eco-certification, sustainable sourcing standards, or consumer demand are harnessed to promote conservation-compatible practices.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Market forces</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/6.4 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/6.4">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/6"/>
        <obo:IAO_0000115 xml:lang="en">A livelihood and economic incentive action in which direct financial payments or transfers are made to landowners, communities, or individuals in exchange for managing land in a conservation-compatible manner.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Conservation payments</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/elmo/cas/6.5 -->

    <owl:Class rdf:about="https://w3id.org/elmo/cas/6.5">
        <rdfs:subClassOf rdf:resource="https://w3id.org/elmo/cas/6"/>
        <obo:IAO_0000115 xml:lang="en">A livelihood and economic incentive action in which the cultural, spiritual, aesthetic, or intrinsic values of biodiversity are recognised and promoted to motivate conservation behaviour.</obo:IAO_0000115>
        <dce:source rdf:resource="https://www.iucnredlist.org/resources/conservation-actions"/>
        <rdfs:label xml:lang="en">Non-monetary values</rdfs:label>
    </owl:Class>
    


